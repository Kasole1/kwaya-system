<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// ============ DATA STRUCTURES ============
let incomeSources = [];
let incomeRecords = [];
let pieChart = null;
let barChart = null;

// ============ LOAD DATA FROM API ============
async function loadIncomeData() {
    try {
        const response = await fetch('/api/mapato/data');
        const data = await response.json();
        if (data.success) {
            incomeSources = data.sources || [];
            incomeRecords = data.records || [];
            renderAll();
        } else {
            // Load default data if no data
            loadDefaultData();
        }
    } catch(e) {
        console.log('No data found, loading defaults');
        loadDefaultData();
    }
}

function loadDefaultData() {
    incomeSources = [
        { id: 1, name: "Ada za Kwaya", color: "#1a2a6e", target: 5000000, description: "Ada za kila mwezi kwa wanakwaya", icon: "💰" },
        { id: 2, name: "Penalty (Utoro)", color: "#dc3545", target: 2000000, description: "Faini za kutokuhudhuria", icon: "❌" },
        { id: 3, name: "Penalty (Chelewa)", color: "#fd7e14", target: 1000000, description: "Faini za kuchelewa", icon: "⏱️" },
        { id: 4, name: "Wafadhili", color: "#28a745", target: 3000000, description: "Michango kutoka kwa wafadhili", icon: "🤝" },
        { id: 5, name: "Mauzo (T-Shirts)", color: "#17a2b8", target: 1500000, description: "Mauzo ya T-Shirts", icon: "👕" },
        { id: 6, name: "Mauzo (CD/DVD)", color: "#9b59b6", target: 500000, description: "Mauzo ya CD na DVD", icon: "💿" },
        { id: 7, name: "Digital Platforms", color: "#e83e8c", target: 1000000, description: "YouTube, Spotify, TikTok", icon: "📱" },
        { id: 8, name: "Marafiki wa Kwaya", color: "#20c997", target: 1000000, description: "Michango ya marafiki", icon: "👥" }
    ];
    
    // Generate some sample records
    const today = new Date();
    incomeRecords = [];
    for (let i = 0; i < 20; i++) {
        const source = incomeSources[Math.floor(Math.random() * incomeSources.length)];
        const date = new Date(today);
        date.setDate(today.getDate() - Math.floor(Math.random() * 90));
        incomeRecords.push({
            id: i + 1,
            source_id: source.id,
            source_name: source.name,
            amount: Math.floor(Math.random() * 500000) + 10000,
            date: date.toISOString().split('T')[0],
            note: `Mapato kutoka ${source.name}`
        });
    }
    
    renderAll();
}

// ============ RENDER ALL ============
function renderAll() {
    renderSourcesGrid();
    updateSummaryStats();
    updateCharts();
}

function renderSourcesGrid() {
    const grid = document.getElementById('sourcesGrid');
    if (!grid) return;
    
    const total = incomeRecords.reduce((sum, r) => sum + r.amount, 0);
    
    // Calculate total per source
    const sourceTotals = {};
    incomeRecords.forEach(record => {
        if (!sourceTotals[record.source_id]) {
            sourceTotals[record.source_id] = 0;
        }
        sourceTotals[record.source_id] += record.amount;
    });
    
    // Sort by total amount (largest first)
    const sortedSources = [...incomeSources].sort((a, b) => {
        const totalA = sourceTotals[a.id] || 0;
        const totalB = sourceTotals[b.id] || 0;
        return totalB - totalA;
    });
    
    grid.innerHTML = sortedSources.map(source => {
        const totalAmount = sourceTotals[source.id] || 0;
        const percentage = total > 0 ? ((totalAmount / total) * 100).toFixed(1) : 0;
        const target = source.target || 0;
        const progress = target > 0 ? (totalAmount / target) * 100 : 0;
        
        return `
            <div class="source-card" onclick="showSourceDetails(${source.id})">
                <div class="source-card-header" style="background: linear-gradient(135deg, ${source.color}, ${adjustColor(source.color, -20)})">
                    <div class="source-name">
                        <span>${source.icon || '💰'}</span>
                        <span>${escapeHtml(source.name)}</span>
                    </div>
                    <div class="source-percentage">${percentage}%</div>
                </div>
                <div class="source-card-body">
                    <div class="amount-row">
                        <span class="amount-label">Jumla ya Mapato</span>
                        <span class="amount-value">TSh ${totalAmount.toLocaleString()}</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: ${Math.min(progress, 100)}%; background: linear-gradient(90deg, ${source.color}, ${adjustColor(source.color, -20)})"></div>
                    </div>
                    <div class="target-info">
                        <span>🎯 Lengo: TSh ${target.toLocaleString()}</span>
                        <span class="${progress >= 100 ? 'days-safe' : 'days-urgent'}">${progress.toFixed(0)}% imefikiwa</span>
                    </div>
                    <button class="edit-btn" onclick="event.stopPropagation(); openAddIncomeModal(${source.id})">➕ Ongeza Mapato</button>
                </div>
            </div>
        `;
    }).join('');
}

function adjustColor(color, percent) {
    // Simple color adjustment for gradient
    return color;
}

function updateSummaryStats() {
    const total = incomeRecords.reduce((sum, r) => sum + r.amount, 0);
    document.getElementById('totalAmount').innerHTML = `TSh ${total.toLocaleString()}`;
    document.getElementById('summaryTotal').innerHTML = `TSh ${total.toLocaleString()}`;
    
    // Monthly total
    const now = new Date();
    const currentMonth = now.getMonth();
    const currentYear = now.getFullYear();
    const monthlyTotal = incomeRecords.filter(r => {
        const d = new Date(r.date);
        return d.getMonth() === currentMonth && d.getFullYear() === currentYear;
    }).reduce((sum, r) => sum + r.amount, 0);
    document.getElementById('summaryMonthly').innerHTML = `TSh ${monthlyTotal.toLocaleString()}`;
    
    // Weekly total
    const oneWeekAgo = new Date(now);
    oneWeekAgo.setDate(now.getDate() - 7);
    const weeklyTotal = incomeRecords.filter(r => new Date(r.date) >= oneWeekAgo).reduce((sum, r) => sum + r.amount, 0);
    document.getElementById('summaryWeekly').innerHTML = `TSh ${weeklyTotal.toLocaleString()}`;
    
    // Target total
    const totalTarget = incomeSources.reduce((sum, s) => sum + (s.target || 0), 0);
    document.getElementById('summaryTarget').innerHTML = `TSh ${totalTarget.toLocaleString()}`;
}

function updateCharts() {
    const total = incomeRecords.reduce((sum, r) => sum + r.amount, 0);
    
    // Calculate per source
    const sourceTotals = {};
    incomeSources.forEach(s => { sourceTotals[s.id] = { name: s.name, color: s.color, total: 0 }; });
    incomeRecords.forEach(r => {
        if (sourceTotals[r.source_id]) {
            sourceTotals[r.source_id].total += r.amount;
        }
    });
    
    const pieData = Object.values(sourceTotals).filter(s => s.total > 0);
    const pieLabels = pieData.map(s => s.name);
    const pieValues = pieData.map(s => s.total);
    const pieColors = pieData.map(s => s.color);
    
    // Pie Chart
    const pieCtx = document.getElementById('pieChart').getContext('2d');
    if (pieChart) pieChart.destroy();
    pieChart = new Chart(pieCtx, {
        type: 'pie',
        data: {
            labels: pieLabels,
            datasets: [{ data: pieValues, backgroundColor: pieColors, borderWidth: 2 }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { position: 'bottom' },
                tooltip: { callbacks: { label: (ctx) => `${ctx.label}: TSh ${ctx.raw.toLocaleString()} (${((ctx.raw / total) * 100).toFixed(1)}%)` } }
            }
        }
    });
    
    // Bar Chart - Monthly trends
    const monthlyData = {};
    for (let i = 5; i >= 0; i--) {
        const d = new Date();
        d.setMonth(d.getMonth() - i);
        const key = `${d.getFullYear()}-${d.getMonth() + 1}`;
        monthlyData[key] = { month: d.toLocaleString('default', { month: 'short' }), total: 0 };
    }
    incomeRecords.forEach(r => {
        const d = new Date(r.date);
        const key = `${d.getFullYear()}-${d.getMonth() + 1}`;
        if (monthlyData[key]) monthlyData[key].total += r.amount;
    });
    
    const barLabels = Object.values(monthlyData).map(m => m.month);
    const barValues = Object.values(monthlyData).map(m => m.total);
    
    const barCtx = document.getElementById('barChart').getContext('2d');
    if (barChart) barChart.destroy();
    barChart = new Chart(barCtx, {
        type: 'bar',
        data: {
            labels: barLabels,
            datasets: [{ label: 'Mapato (TSh)', data: barValues, backgroundColor: '#1a2a6e', borderRadius: 10 }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            scales: { y: { beginAtZero: true, ticks: { callback: (v) => `TSh ${v.toLocaleString()}` } } }
        }
    });
}

// ============ MODAL FUNCTIONS ============
function openAddSourceModal() {
    document.getElementById('addSourceModal').classList.add('active');
    document.getElementById('addSourceForm').reset();
}

function closeAddSourceModal() {
    document.getElementById('addSourceModal').classList.remove('active');
}

async function showSourceDetails(sourceId) {
    const source = incomeSources.find(s => s.id === sourceId);
    if (!source) return;
    
    const sourceRecords = incomeRecords.filter(r => r.source_id === sourceId);
    const totalAmount = sourceRecords.reduce((sum, r) => sum + r.amount, 0);
    const target = source.target || 0;
    const progress = target > 0 ? (totalAmount / target) * 100 : 0;
    const daysRemaining = 30; // Calculate based on target date
    
    let transactionsHtml = '';
    sourceRecords.sort((a, b) => new Date(b.date) - new Date(a.date)).forEach(record => {
        transactionsHtml += `
            <div class="transaction-item">
                <div>
                    <div class="transaction-date">📅 ${record.date}</div>
                    <div style="font-size: 12px;">${escapeHtml(record.note || 'Mapato')}</div>
                </div>
                <div class="transaction-amount">TSh ${record.amount.toLocaleString()}</div>
            </div>
        `;
    });
    
    document.getElementById('detailTitle').innerHTML = `📊 ${escapeHtml(source.name)}`;
    document.getElementById('detailBody').innerHTML = `
        <div class="detail-stats">
            <div class="detail-stat">
                <div class="label">Jumla ya Mapato</div>
                <div class="value">TSh ${totalAmount.toLocaleString()}</div>
            </div>
            <div class="detail-stat">
                <div class="label">Lengo la Mwaka</div>
                <div class="value">TSh ${target.toLocaleString()}</div>
            </div>
            <div class="detail-stat">
                <div class="label">Ufanisi</div>
                <div class="value">${progress.toFixed(1)}%</div>
            </div>
            <div class="detail-stat">
                <div class="label">Siku Zilizobaki</div>
                <div class="value days-urgent">${daysRemaining} siku</div>
            </div>
        </div>
        <div class="progress-bar" style="margin-bottom: 20px;">
            <div class="progress-fill" style="width: ${Math.min(progress, 100)}%; background: linear-gradient(90deg, ${source.color}, ${adjustColor(source.color, -20)})"></div>
        </div>
        <h4 style="color: #1a2a6e; margin-bottom: 15px;">📋 Historia ya Mapato</h4>
        <div class="transaction-list">
            ${transactionsHtml || '<div style="text-align:center; padding:20px;">📭 Hakuna rekodi za mapato</div>'}
        </div>
        <button class="edit-btn" onclick="closeSourceDetailModal(); openAddIncomeModal(${sourceId})" style="margin-top: 20px;">➕ Ongeza Mapato</button>
    `;
    document.getElementById('sourceDetailModal').classList.add('active');
}

function closeSourceDetailModal() {
    document.getElementById('sourceDetailModal').classList.remove('active');
}

function openAddIncomeModal(sourceId = null) {
    const sourceSelect = document.getElementById('incomeSource');
    sourceSelect.innerHTML = incomeSources.map(s => `<option value="${s.id}" ${s.id === sourceId ? 'selected' : ''}>${escapeHtml(s.name)}</option>`).join('');
    document.getElementById('incomeDate').value = new Date().toISOString().split('T')[0];
    document.getElementById('addIncomeModal').classList.add('active');
}

function closeAddIncomeModal() {
    document.getElementById('addIncomeModal').classList.remove('active');
}

// ============ FORM SUBMISSIONS ============
document.getElementById('addSourceForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const newSource = {
        name: document.getElementById('sourceName').value,
        color: document.getElementById('sourceColor').value,
        target: parseInt(document.getElementById('sourceTarget').value) || 0,
        description: document.getElementById('sourceDescription').value,
        icon: '💰'
    };
    
    try {
        const response = await fetch('/api/mapato/source/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(newSource)
        });
        const result = await response.json();
        if (result.success) {
            alert('✅ Chanzo kimeongezwa!');
            closeAddSourceModal();
            loadIncomeData();
        } else {
            alert('❌ ' + (result.message || 'Kuna tatizo'));
        }
    } catch(e) {
        // Add locally if API fails
        newSource.id = incomeSources.length + 1;
        incomeSources.push(newSource);
        renderAll();
        closeAddSourceModal();
        alert('✅ Chanzo kimeongezwa (local)');
    }
});

document.getElementById('addIncomeForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const newIncome = {
        source_id: parseInt(document.getElementById('incomeSource').value),
        amount: parseInt(document.getElementById('incomeAmount').value),
        date: document.getElementById('incomeDate').value,
        note: document.getElementById('incomeNote').value
    };
    
    if (!newIncome.amount || newIncome.amount <= 0) {
        alert('Tafadhali weka kiasi sahihi');
        return;
    }
    
    try {
        const response = await fetch('/api/mapato/income/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(newIncome)
        });
        const result = await response.json();
        if (result.success) {
            alert('✅ Mapato yameongezwa!');
            closeAddIncomeModal();
            loadIncomeData();
        } else {
            alert('❌ ' + (result.message || 'Kuna tatizo'));
        }
    } catch(e) {
        // Add locally if API fails
        const source = incomeSources.find(s => s.id === newIncome.source_id);
        newIncome.id = incomeRecords.length + 1;
        newIncome.source_name = source ? source.name : 'Unknown';
        incomeRecords.push(newIncome);
        renderAll();
        closeAddIncomeModal();
        alert('✅ Mapato yameongezwa (local)');
    }
});

function escapeHtml(text) {
    if (!text) return '';
    return text.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
    });
}

// Initialize
loadIncomeData();
// ============ TARGET SETTINGS FUNCTIONS ============

let globalTarget = 10000000; // Default target TSh 10M

async function openTargetSettings() {
    try {
        // Get current global target
        const response = await fetch('/api/mapato/settings/get');
        const data = await response.json();
        if (data.success) {
            globalTarget = data.global_target || 10000000;
            document.getElementById('globalTarget').value = globalTarget;
        }
        
        // Build targets list
        let html = '';
        for (let i = 0; i < incomeSources.length; i++) {
            const source = incomeSources[i];
            const currentTarget = source.target || 0;
            html += `
                <div style="background: #f8f9fa; border-radius: 12px; padding: 15px; margin-bottom: 10px; border-left: 4px solid ${source.color};">
                    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                        <div>
                            <strong style="font-size: 14px;">${source.icon || '💰'} ${escapeHtml(source.name)}</strong>
                            <div style="font-size: 11px; color: #666;">Lengo la sasa: TSh ${currentTarget.toLocaleString()}</div>
                        </div>
                        <input type="number" id="target_${source.id}" value="${currentTarget}" style="width: 180px; padding: 10px; border: 2px solid #e0e0e0; border-radius: 12px; text-align: right;">
                    </div>
                </div>
            `;
        }
        document.getElementById('targetsList').innerHTML = html;
        document.getElementById('targetSettingsModal').classList.add('active');
    } catch(e) {
        console.error(e);
        alert('Kuna tatizo la kupata malengo');
    }
}

function closeTargetSettingsModal() {
    document.getElementById('targetSettingsModal').classList.remove('active');
}

async function saveAllTargets() {
    const newGlobalTarget = parseInt(document.getElementById('globalTarget').value) || 0;
    
    // Collect targets per source
    const sourceTargets = [];
    for (let i = 0; i < incomeSources.length; i++) {
        const source = incomeSources[i];
        const targetInput = document.getElementById(`target_${source.id}`);
        if (targetInput) {
            const targetValue = parseInt(targetInput.value) || 0;
            sourceTargets.push({
                source_id: source.id,
                target: targetValue
            });
        }
    }
    
    try {
        const response = await fetch('/api/mapato/settings/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                global_target: newGlobalTarget,
                source_targets: sourceTargets
            })
        });
        const result = await response.json();
        if (result.success) {
            alert('✅ Malengo yamehifadhiwa kikamilifu!');
            closeTargetSettingsModal();
            // Update local data
            for (let i = 0; i < incomeSources.length; i++) {
                const targetData = sourceTargets.find(st => st.source_id === incomeSources[i].id);
                if (targetData) {
                    incomeSources[i].target = targetData.target;
                }
            }
            // Update summary target
            document.getElementById('summaryTarget').innerHTML = `TSh ${newGlobalTarget.toLocaleString()}`;
            // Re-render to update progress bars
            renderSourcesGrid();
        } else {
            alert('❌ ' + (result.message || 'Kuna tatizo, jaribu tena'));
        }
    } catch(e) {
        console.error(e);
        alert('❌ Kuna tatizo la mtandao');
    }
}
</script>
