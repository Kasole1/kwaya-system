                            <td style="padding:10px;">${off.remaining_debt > 0 ? '<span style="color:#dc3545;">TSh ' + formatNumber(off.remaining_debt) + '</span>' : '<span style="color:#28a745;">✓ Imelipwa</span>'}</td>
                        </tr>
                    `;
                });
                
                html += `</tbody></table></div>`;
            }
            
            html += `</div></div></div>`;
            
            const existingModal = document.getElementById('frequentModal');
            if (existingModal) existingModal.remove();
            document.body.insertAdjacentHTML('beforeend', html);
            document.body.style.overflow = 'hidden';
        }
    }
    
    function closeFrequentModal() {
        const modal = document.getElementById('frequentModal');
        if (modal) modal.remove();
        document.body.style.overflow = '';
    }
    
    function formatNumber(num) {
        if (!num && num !== 0) return '0';
        return Math.round(num).toLocaleString();
    }
    
    function escapeHtml(text) {
        if (!text) return '';
        return text.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
    
