                            <div style="color:#666;">🎤 ${escapeHtml(voice)}</div>
                        </div>
                        
                        <div style="background:#f8f9fa; border-radius:16px; padding:15px; margin-bottom:20px;">
                            <div style="display:flex; justify-content:space-between; padding:10px 0;">
                                <span>💰 Penalty Inayodaiwa:</span>
                                <span style="color:#dc3545; font-weight:bold;">TSh ${formatNumber(amount)}</span>
                            </div>
                        </div>
                        
                        <div id="remainingDisplay" style="background:linear-gradient(135deg,#1a2a6e,#2a3a7e); border-radius:16px; padding:15px; margin-bottom:20px; text-align:center;">
