    <div class="voice-penalty-card tenor-card">
        <div class="voice-card-header">
            <span class="voice-icon">🎵</span>
            <span class="voice-name">TENOR</span>
            <span class="penalty-badge" id="tenorPenaltyCount">0</span>
        </div>
        <div class="penalty-list" id="tenorPenaltyList">
            <div class="no-penalty">✨ Hakuna penalty kwa sauti hii</div>
        </div>
    </div>
    
    <!-- Bass Penalties -->
    <div class="voice-penalty-card bass-card">
        <div class="voice-card-header">
            <span class="voice-icon">🎵</span>
            <span class="voice-name">BASS</span>
            <span class="penalty-badge" id="bassPenaltyCount">0</span>
        </div>
        <div class="penalty-list" id="bassPenaltyList">
            <div class="no-penalty">✨ Hakuna penalty kwa sauti hii</div>
        </div>
    </div>
</div>

<!-- Frequent Offenders Modal -->
<div id="frequentModal" class="modal">
    <div class="modal-content" style="max-width: 800px;">
        <div class="modal-header">
            <h2>🏆 Wadaiwa wa Mara kwa Mara (Top 5 kwa kila Sauti)</h2>
            <button class="close-modal" onclick="closeFrequentModal()">&times;</button>
        </div>
        <div class="modal-body" id="frequentModalBody">
            <div style="text-align: center; padding: 30px;">Loading...</div>
        </div>
    </div>
</div>

<!-- Fine Payment Modal -->
<div id="finePaymentModal" class="modal">
    <div class="modal-content" style="max-width: 500px;">
        <div class="modal-header">
            <h2>💰 Lipa Penalty</h2>
            <button class="close-modal" onclick="closeFineModal()">&times;</button>
        </div>
        <div class="modal-body" id="fineModalBody">
            <div style="text-align: center; padding: 30px;">Loading...</div>
        </div>
    </div>
</div>

<script>
// ========== PENALTY LIST FUNCTIONS ==========
let penaltyData = [];

async function loadPenaltyList() {
    try {
        const response = await fetch('/api/mahudhurio/penalty_list');
        const data = await response.json();
        if (data.success) {
            penaltyData = data.penalties || [];
            renderPenaltyTable();
        }
    } catch(e) {
        console.error('Error:', e);
        document.getElementById('penaltyTableBody').innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;">❌ Error loading data</td></tr>';
    }
}

function renderPenaltyTable() {
    const tbody = document.getElementById('penaltyTableBody');
    const countSpan = document.getElementById('penaltyCount');
    
    if (!tbody) return;
    
    if (!penaltyData || penaltyData.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;">📭 Hakuna wanakwaya wenye penalty</td></tr>';
        if (countSpan) countSpan.innerText = '0';
        return;
    }
    
    if (countSpan) countSpan.innerText = penaltyData.length;
    
    tbody.innerHTML = penaltyData.map((p, idx) => {
        let penaltyTypeHtml = p.penalty_type === 'utoro' 
            ? '<span style="background:#dc3545; color:white; padding:3px 10px; border-radius:20px; font-size:11px;">❌ Mtoro</span>'
            : '<span style="background:#fd7e14; color:white; padding:3px 10px; border-radius:20px; font-size:11px;">⏱️ Amechelewa</span>';
        
        let daysClass = '';
        let daysText = p.days_until_double || 0;
        if (daysText <= 3) daysClass = 'style="color:#dc3545; font-weight:bold;"';
        else if (daysText <= 7) daysClass = 'style="color:#fd7e14; font-weight:bold;"';
        else daysClass = 'style="color:#28a745;"';
        
        return `
            <tr>
                <td>${idx + 1}</td>
                <td><strong>${escapeHtml(p.member_number || 'N/A')}</strong></td>
                <td><strong>${escapeHtml(p.jina)}</strong> <span style="color:#666;">(${escapeHtml(p.sauti)})</span></td>
                <td>${penaltyTypeHtml}</td>
                <td>${escapeHtml(p.tukio)}</td>
                <td><strong style="color:#dc3545;">TSh ${(p.remaining_amount || p.penalty_amount).toLocaleString()}</strong></td>
                <td ${daysClass}>${daysText} siku</td>
                <td><button class="pay-fine-btn" onclick="openFineModal(${p.member_id}, ${p.penalty_id}, '${escapeHtml(p.jina)}', '${escapeHtml(p.sauti)}', ${p.remaining_amount || p.penalty_amount})">💰 Lipa</button></td>
            </tr>
        `;
    }).join('');
}

let currentFine = {};

function openFineModal(memberId, penaltyId, name, voice, amount) {
    currentFine = { memberId, penaltyId, name, voice, amount };
    
    const modalHtml = `
        <div style="padding:20px;">
            <div style="text-align:center; margin-bottom:20px;">
                <div style="font-size:50px;">💰</div>
                <div style="font-size:20px; font-weight:bold;">${escapeHtml(name)}</div>
                <div style="color:#666;">🎤 ${escapeHtml(voice)}</div>
            </div>
            <div style="background:#f8f9fa; border-radius:16px; padding:15px; margin-bottom:20px;">
                <div style="display:flex; justify-content:space-between;">
                    <span>Penalty Inayodaiwa:</span>
                    <span style="color:#dc3545; font-weight:bold;">TSh ${amount.toLocaleString()}</span>
                </div>
            </div>
            <div class="fine-remaining" style="background:linear-gradient(135deg,#1a2a6e,#2a3a7e); border-radius:16px; padding:15px; margin-bottom:20px; text-align:center;">
                <div style="color:#FFD700;">DENI LILILOBAKI</div>
                <div style="color:white; font-size:28px; font-weight:bold;" id="remainingAmount">TSh ${amount.toLocaleString()}</div>
            </div>
            <div style="display:flex; gap:12px; margin-bottom:20px;">
                <button onclick="selectFineOption('full')" id="fullOptionBtn" style="flex:1; background:linear-gradient(135deg,#28a745,#1e7e34); color:white; padding:12px; border:none; border-radius:40px; cursor:pointer;">💰 Lipa Kamili</button>
                <button onclick="selectFineOption('partial')" id="partialOptionBtn" style="flex:1; background:#fd7e14; color:white; padding:12px; border:none; border-radius:40px; cursor:pointer;">📊 Lipa Sehemu</button>
            </div>
            <div id="partialAmountDiv" style="display:none; margin-bottom:20px;">
                <label>Kiasi cha Kulipa (TSh)</label>
                <input type="number" id="fineAmount" value="5000" style="width:100%; padding:12px; border:2px solid #ddd; border-radius:16px;">
            </div>
            <div style="margin-bottom:20px;">
                <label>Maelezo</label>
                <input type="text" id="fineNote" placeholder="Malipo ya penalty" style="width:100%; padding:12px; border:2px solid #ddd; border-radius:16px;">
            </div>
            <button onclick="submitFinePayment()" style="background:linear-gradient(135deg,#1a2a6e,#2a3a7e); color:#FFD700; width:100%; padding:14px; border:none; border-radius:40px; cursor:pointer;">💾 Thibitisha Malipo</button>
        </div>
    `;
    
    document.getElementById('fineModalBody').innerHTML = modalHtml;
    document.getElementById('finePaymentModal').classList.add('active');
}

function selectFineOption(option) {
    const fullBtn = document.getElementById('fullOptionBtn');
    const partialBtn = document.getElementById('partialOptionBtn');
    const partialDiv = document.getElementById('partialAmountDiv');
    
    if (option === 'full') {
        fullBtn.style.background = 'linear-gradient(135deg,#28a745,#1e7e34)';
        partialBtn.style.background = '#fd7e14';
        partialDiv.style.display = 'none';
    } else {
        fullBtn.style.background = '#6c757d';
        partialBtn.style.background = 'linear-gradient(135deg,#fd7e14,#e67e22)';
        partialDiv.style.display = 'block';
    }
}

async function submitFinePayment() {
    const isPartial = document.getElementById('partialAmountDiv').style.display === 'block';
    let amount = isPartial ? parseFloat(document.getElementById('fineAmount').value) : currentFine.amount;
    const note = document.getElementById('fineNote').value || 'Malipo ya penalty';
    
    if (isNaN(amount) || amount <= 0) {
        alert('Tafadhali weka kiasi sahihi');
        return;
    }
    
    const response = await fetch('/api/mahudhurio/pay_penalty', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            penalty_id: currentFine.penaltyId,
            member_id: currentFine.memberId,
            amount: amount,
            note: note
        })
    });
    
    const result = await response.json();
    if (result.success) {
        alert(result.message);
        closeFineModal();
        loadPenaltyList();
        location.reload();
    } else {
        alert('Error: ' + result.message);
    }
}

function closeFineModal() {
    document.getElementById('finePaymentModal').classList.remove('active');
}

async function openFrequentOffenders() {
    const response = await fetch('/api/mahudhurio/frequent_offenders');
    const data = await response.json();
    
    if (data.success) {
        let html = '';
        for (const [voice, offenders] of Object.entries(data.offenders)) {
            if (offenders.length === 0) continue;
            
            let voiceColor = voice === 'Soprano' ? 'linear-gradient(135deg,#FF69B4,#FF1493)' :
                           voice === 'Alto' ? 'linear-gradient(135deg,#9370DB,#7B2FBE)' :
                           voice === 'Tenor' ? 'linear-gradient(135deg,#4169E1,#1E3A8A)' :
                           'linear-gradient(135deg,#2F4F4F,#1E3A3A)';
            
            html += `
                <div style="margin-bottom:25px; border-radius:16px; overflow:hidden; border:1px solid #e0e0e0;">
                    <div style="background:${voiceColor}; padding:12px 20px; color:white; font-weight:bold;">🎵 ${voice}</div>
                    <table style="width:100%;">
                        <thead><tr style="background:#f8f9fa;"><th>#</th><th>Jina</th><th>Mara</th><th>Jumla ya Penalty</th><th>Deni</th></tr></thead>
                        <tbody>
                            ${offenders.map((off, idx) => `
                                <tr>
                                    <td style="padding:10px;">${idx + 1}</td>
                                    <td><strong>${escapeHtml(off.jina)}</strong></td>
                                    <td><span style="background:#fd7e14;color:white;padding:2px 10px;border-radius:20px;">${off.offence_count} mara</span></td>
                                    <td style="color:#dc3545;">TSh ${off.total_penalty.toLocaleString()}</td>
                                    <td>${off.remaining_debt > 0 ? '<span style="color:#dc3545;">TSh ' + off.remaining_debt.toLocaleString() + '</span>' : '<span style="color:#28a745;">✓ Imelipwa</span>'}</td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
            `;
        }
        document.getElementById('frequentModalBody').innerHTML = html;
        document.getElementById('frequentModal').classList.add('active');
    }
}

function closeFrequentModal() {
    document.getElementById('frequentModal').classList.remove('active');
}

function escapeHtml(text) {
    if (!text) return '';
    return text.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
    });
}

// Load penalty list when page loads
document.addEventListener('DOMContentLoaded', loadPenaltyList);
</script>
{% endblock %}