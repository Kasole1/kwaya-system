        html += `</div><div class="settings-summary"><div class="summary-item">📊 <strong>${tukioList.length}</strong> Aina za Matukio</div><div class="summary-item">💰 Penalty huongezeka mara mbili baada ya siku ${settingsMap[Object.keys(settingsMap)[0]]?.siku_za_kudouble || 10}</div><div class="summary-item">🚫 Kusimamishwa baada ya siku 30</div><button class="settings-close" onclick="closeSettingsModal()">✖️ FUNGA</button></div></div>`;
