    async function openFineModal(memberId, penaltyId, name, voice, amount) {
        currentFine.memberId = memberId;
        currentFine.penaltyId = penaltyId;
        currentFine.memberName = name;
        currentFine.voice = voice;
        currentFine.amount = amount;
        currentFine.remaining = amount;
        
        const modalHtml = `
            <div id="finePaymentModal" style="display:flex; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); backdrop-filter:blur(5px); z-index:10000; justify-content:center; align-items:center;">
