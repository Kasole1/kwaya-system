        for (const voice of ['Soprano','Alto','Tenor','Bass']) { 
            voiceStates[voice]=true; 
            const s=document.getElementById(`${voice}Section`); 
            const b=document.querySelector(`.voice-toggle[data-voice="${voice}"]`); 
            if(s) s.classList.remove('hidden'); 
            if(b) b.classList.add('active'); 
        } 
