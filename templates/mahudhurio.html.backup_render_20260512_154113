    let penaltyData = [];
    
        async function loadPenaltyList() {
        try {
            const response = await fetch('/api/mahudhurio/penalty_list');
            const data = await response.json();
            console.log("Penalty data received:", data);
            if (data.success) {
                penaltyData = data.penalties || [];
                console.log("Penalties count:", penaltyData.length);
                renderPenaltyTable();
            } else {
                penaltyData = [];
                renderPenaltyTable();
            }
        } catch(e) {
            console.error('Error loading penalty list:', e);
            penaltyData = [];
            renderPenaltyTable();
        }
    }
    
    function renderPenaltyTable() {
    // Group penalties by voice
    const voices = ['Soprano', 'Alto', 'Tenor', 'Bass'];
    
    voices.forEach(voice => {
        const voicePenalties = penaltyData.filter(p => p.sauti === voice);
        const container = document.getElementById(`${voice.toLowerCase()}PenaltyList`);
        const countSpan = document.getElementById(`${voice.toLowerCase()}PenaltyCount`);
        
        if (countSpan) countSpan.innerText = voicePenalties.length;
        
        if (!container) return;
        
        if (voicePenalties.length === 0) {
            container.innerHTML = '<div class="no-penalty">✨ Hakuna penalty kwa sauti hii</div>';
            return;
        }
        
        container.innerHTML = voicePenalties.map(p => {
            let penaltyTypeClass = p.penalty_type === 'utoro' ? 'utoro' : 'chelewa';
            let penaltyTypeText = p.penalty_type === 'utoro' ? '❌ Mtoro' : '⏱️ Amechelewa';
            
            let daysClass = '';
            let daysText = p.days_until_double || 0;
            if (daysText <= 3) daysClass = 'urgent';
            else if (daysText <= 7) daysClass = 'warning';
            else daysClass = 'safe';
            
            return `
                <div class="penalty-item">
                    <div class="penalty-info">
                        <div class="penalty-member">
                            <div>${escapeHtml(p.jina)}</div>
                            <div class="penalty-member-number">${escapeHtml(p.member_number || 'N/A')}</div>
                        </div>
                        <div class="penalty-type ${penaltyTypeClass}">${penaltyTypeText}</div>
                        <div>${escapeHtml(p.tukio)}</div>
                        <div class="penalty-amount">TSh ${(p.remaining_amount || p.penalty_amount).toLocaleString()}</div>
                        <div class="penalty-days ${daysClass}">⏰ ${daysText} siku</div>
                    </div>
                    <button class="pay-btn" onclick="openFineModal(${p.member_id}, ${p.penalty_id}, '${escapeHtml(p.jina)}', '${escapeHtml(p.sauti)}', ${p.remaining_amount || p.penalty_amount})">
                        💰 Lipa
                    </button>
                </div>
            `;
        }).join('');
    });
}
    
