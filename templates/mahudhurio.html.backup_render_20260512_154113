    async function saveSinglePenalty(tukio) {
        const penalty_utoro = document.getElementById(`utoro_${tukio}`).value;
        const penalty_kwa_dakika = document.getElementById(`dakika_${tukio}`).value;
        const siku_za_kudouble = document.getElementById(`siku_${tukio}`).value;
        const response = await fetch('/api/mahudhurio/settings/update', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tukio, penalty_utoro, penalty_kwa_dakika, siku_za_kudouble })
        });
        if (response.ok) {
            const btn = event.target;
            const originalText = btn.innerHTML;
            btn.innerHTML = '✅ IMEFANIKIWA';
            btn.style.background = '#28a745';
            setTimeout(() => { btn.innerHTML = originalText; btn.style.background = 'linear-gradient(135deg, #FFD700 0%, #FFA500 100%)'; }, 1500);
            showNotification(`✅ Settings za ${tukio} zimehifadhiwa!`, 'success');
            loadPenaltySettings();
        } else { 
            showNotification('❌ Kuna tatizo, tafadhali jaribu tena!', 'error');
        }
    }
    
