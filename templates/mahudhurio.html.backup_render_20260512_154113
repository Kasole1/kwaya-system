                            <button onclick="selectFineOption('partial')" id="partialOptionBtn" style="flex:1; background:#fd7e14; color:white; padding:12px; border:none; border-radius:40px; font-weight:bold; cursor:pointer;">📊 Lipa Sehemu</button>
                        </div>
                        
                        <div id="partialAmountDiv" style="display:none; margin-bottom:20px;">
                            <label style="display:block; font-weight:bold; margin-bottom:8px;">💰 Kiasi cha Kulipa (TSh)</label>
                            <input type="number" id="fineAmount" value="5000" style="width:100%; padding:12px; border:2px solid #ddd; border-radius:16px; font-size:16px;">
                        </div>
                        
                        <div style="margin-bottom:20px;">
                            <label style="display:block; font-weight:bold; margin-bottom:8px;">📝 Maelezo</label>
                            <input type="text" id="fineNote" placeholder="Malipo ya penalty" style="width:100%; padding:12px; border:2px solid #ddd; border-radius:16px;">
                        </div>
                        
                        <button onclick="submitFinePayment()" style="background:linear-gradient(135deg,#1a2a6e,#2a3a7e); color:#FFD700; width:100%; padding:14px; border:none; border-radius:40px; font-weight:bold; font-size:16px; cursor:pointer;">💾 Thibitisha Malipo</button>
                    </div>
                </div>
            </div>
        `;
        
        // Remove existing modal if any
        const existingModal = document.getElementById('finePaymentModal');
        if (existingModal) existingModal.remove();
        
        document.body.insertAdjacentHTML('beforeend', modalHtml);
        document.body.style.overflow = 'hidden';
    }
    
    function selectFineOption(option) {
        const fullBtn = document.getElementById('fullOptionBtn');
        const partialBtn = document.getElementById('partialOptionBtn');
        const partialDiv = document.getElementById('partialAmountDiv');
        
        if (option === 'full') {
            fullBtn.style.background = 'linear-gradient(135deg,#28a745,#1e7e34)';
            partialBtn.style.background = '#fd7e14';
            partialDiv.style.display = 'none';
        } else {
            fullBtn.style.background = '#6c757d';
            partialBtn.style.background = 'linear-gradient(135deg,#fd7e14,#e67e22)';
            partialDiv.style.display = 'block';
        }
    }
    
    async function submitFinePayment() {
        const isPartial = document.getElementById('partialAmountDiv').style.display === 'block';
        let amount = isPartial ? parseFloat(document.getElementById('fineAmount').value) : currentFine.amount;
        const note = document.getElementById('fineNote').value || 'Malipo ya penalty';
        
        if (isNaN(amount) || amount <= 0) {
            alert('Tafadhali weka kiasi sahihi');
            return;
        }
        
        const submitBtn = event?.target;
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '⏳ Inachakata...';
        }
        
        try {
            const response = await fetch('/api/mahudhurio/pay_penalty', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    penalty_id: currentFine.penaltyId,
                    member_id: currentFine.memberId,
                    amount: amount,
                    note: note
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                alert(`✅ ${result.message}`);
                closeFineModal();
                loadPenaltyList(); // Refresh penalty list
                location.reload(); // Reload page to update everything
            } else {
                alert('❌ ' + (result.message || 'Kuna tatizo, jaribu tena'));
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '💾 Thibitisha Malipo';
                }
            }
        } catch(e) {
            alert('❌ Kuna tatizo la mtandao');
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '💾 Thibitisha Malipo';
            }
        }
    }
    
    function closeFineModal() {
        const modal = document.getElementById('finePaymentModal');
        if (modal) modal.remove();
        document.body.style.overflow = '';
    }
    
    async function openFrequentOffenders() {
        const response = await fetch('/api/mahudhurio/frequent_offenders');
        const data = await response.json();
        
        if (data.success) {
            let html = `
                <div id="frequentModal" style="display:flex; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); backdrop-filter:blur(5px); z-index:10000; justify-content:center; align-items:center;">
                    <div style="background:white; border-radius:28px; width:90%; max-width:800px; max-height:85vh; overflow-y:auto;">
                        <div style="background:linear-gradient(135deg,#1a2a6e,#2a3a7e); padding:20px; border-radius:28px 28px 0 0; color:#FFD700; display:flex; justify-content:space-between;">
                            <h3 style="margin:0;">🏆 Wadaiwa wa Mara kwa Mara (Top 5 kwa kila Sauti)</h3>
                            <button onclick="closeFrequentModal()" style="background:rgba(255,255,255,0.2); border:none; color:#FFD700; font-size:24px; cursor:pointer; width:35px; border-radius:50%;">✕</button>
                        </div>
                        <div style="padding:20px;">
            `;
            
            for (const [voice, offenders] of Object.entries(data.offenders)) {
                if (offenders.length === 0) continue;
                
                let voiceColor = '';
                if (voice === 'Soprano') voiceColor = 'linear-gradient(135deg,#FF69B4,#FF1493)';
                else if (voice === 'Alto') voiceColor = 'linear-gradient(135deg,#9370DB,#7B2FBE)';
                else if (voice === 'Tenor') voiceColor = 'linear-gradient(135deg,#4169E1,#1E3A8A)';
                else voiceColor = 'linear-gradient(135deg,#2F4F4F,#1E3A3A)';
                
                html += `
                    <div style="margin-bottom:25px; border-radius:16px; overflow:hidden; border:1px solid #e0e0e0;">
                        <div style="background:${voiceColor}; padding:12px 20px; color:white; font-weight:bold;">
                            🎵 ${voice} - Wadaiwa Bora ${offenders.length}
                        </div>
                        <table style="width:100%; border-collapse:collapse;">
                            <thead>
                                <tr style="background:#f8f9fa;">
                                    <th style="padding:10px; text-align:left;">#</th>
                                    <th style="padding:10px; text-align:left;">Jina</th>
                                    <th style="padding:10px; text-align:left;">Mara</th>
                                    <th style="padding:10px; text-align:left;">Jumla ya Penalty</th>
                                    <th style="padding:10px; text-align:left;">Deni</th>
                                </tr>
                            </thead>
                            <tbody>
                `;
                
                offenders.forEach((off, idx) => {
                    html += `
                        <tr style="border-bottom:1px solid #eee;">
                            <td style="padding:10px;">${idx + 1}</td>
                            <td style="padding:10px;"><strong>${escapeHtml(off.jina)}</strong></td>
