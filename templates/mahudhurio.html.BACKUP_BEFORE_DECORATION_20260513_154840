<script>
let currentTukio = '{{ current_event.tukio }}';
let penaltySettingsCache = {};
let penaltyData = [];
let voiceStates = { Soprano: true, Alto: true, Tenor: true, Bass: true };

// Load penalty settings
async function loadPenaltySettings() {
    const response = await fetch('/api/mahudhurio/penalty_settings');
    const settings = await response.json();
    settings.forEach(s => penaltySettingsCache[s.tukio] = s);
    showPenaltyInfo();
}

function showPenaltyInfo() {
    const selected = document.getElementById('eventSelect').value;
    const s = penaltySettingsCache[selected] || { penalty_utoro: 20000, penalty_kwa_dakika: 1000, siku_za_kudouble: 10 };
    const infoDiv = document.getElementById('penaltyInfoDisplay');
    if (infoDiv) {
        infoDiv.innerHTML = `<div>💰 ${selected}: ❌ Mtoro TSh ${s.penalty_utoro} | ⏱️ Dakika TSh ${s.penalty_kwa_dakika} | ⚠️ Double baada ya siku ${s.siku_za_kudouble}</div>`;
        infoDiv.style.display = 'block';
    }
}

// Toggle status function
function toggleStatus(id, name, sauti) {
    const toggle = document.querySelector(`.toggle-switch[data-id="${id}"]`);
    if (!toggle) return;
    
    const currentStatus = toggle.dataset.status;
    let newStatus, statusText, colorClass;
    
    if (currentStatus === 'present') { 
        newStatus = 'absent'; statusText = 'Mtoro'; colorClass = 'active-red'; 
    } else if (currentStatus === 'absent') { 
        newStatus = 'late'; statusText = 'Amechelewa'; colorClass = 'active-yellow'; 
    } else if (currentStatus === 'late') { 
        newStatus = 'present'; statusText = 'Amehudhuria'; colorClass = 'active-green'; 
    } else { 
        newStatus = 'present'; statusText = 'Amehudhuria'; colorClass = 'active-green'; 
    }
    
    toggle.dataset.status = newStatus;
    toggle.className = `toggle-switch ${colorClass}`;
    
    const statusCell = document.querySelector(`.status-cell-${id}`);
    if (statusCell) statusCell.innerHTML = `<span class="status-${newStatus}">${statusText}</span>`;
    
    const minutesDiv = document.querySelector(`.minutes-cell-${id} .minutes-control`);
    if (minutesDiv) {
        if (newStatus === 'late') {
            minutesDiv.style.display = 'flex';
            const minutesSpan = document.getElementById(`minutes-${id}`);
            const minutes = minutesSpan ? parseInt(minutesSpan.innerText) : 0;
            updatePenalty(id, newStatus, minutes, name, sauti);
        } else {
            minutesDiv.style.display = 'none';
            const minutesSpan = document.getElementById(`minutes-${id}`);
            if (minutesSpan) minutesSpan.innerText = '0';
            updatePenalty(id, newStatus, 0, name, sauti);
        }
    } else {
        updatePenalty(id, newStatus, 0, name, sauti);
    }
}

function changeMinutes(id, delta) {
    const minutesSpan = document.getElementById(`minutes-${id}`);
    if (!minutesSpan) return;
    let minutes = parseInt(minutesSpan.innerText) + delta;
    if (minutes < 0) minutes = 0;
    if (minutes > 120) minutes = 120;
    minutesSpan.innerText = minutes;
    const toggle = document.querySelector(`.toggle-switch[data-id="${id}"]`);
    if (toggle && toggle.dataset.status === 'late') {
        updatePenalty(id, 'late', minutes, null, null);
    }
}

async function updatePenalty(id, status, minutes, name, sauti) {
    const tukio = document.getElementById('eventSelect').value;
    try {
        const response = await fetch('/api/mahudhurio/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ member_id: id, status: status, dakika_chelewa: minutes, tukio: tukio, member_name: name, sauti: sauti })
        });
        const data = await response.json();
        if (data.success) {
            const penaltyCell = document.querySelector(`.penalty-cell-${id}`);
            if (penaltyCell) penaltyCell.innerHTML = `<span class="penalty-amount">TSh ${data.penalty.toLocaleString()}</span>`;
            await loadPenaltyList();
        }
    } catch(e) { console.error(e); }
}

// Penalty list functions
async function loadPenaltyList() {
    try {
        const response = await fetch('/api/mahudhurio/penalty_list');
        const data = await response.json();
        if (data.success) {
            penaltyData = data.penalties || [];
            renderPenaltyTable();
        }
    } catch(e) { console.error(e); }
}

function renderPenaltyTable() {
    const tbody = document.getElementById('penaltyTableBody');
    const countSpan = document.getElementById('penaltyCount');
    if (!tbody) return;
    if (!penaltyData || penaltyData.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;">📭 Hakuna penalty</td></tr>';
        if (countSpan) countSpan.innerText = '0';
        return;
    }
    if (countSpan) countSpan.innerText = penaltyData.length;
    
    let html = '';
    for (let i = 0; i < penaltyData.length; i++) {
        const p = penaltyData[i];
        const badge = p.penalty_type === 'utoro' ? '<span class="penalty-badge-utoro">❌ Mtoro</span>' : '<span class="penalty-badge-chelewa">⏱️ Amechelewa</span>';
        let daysClass = (p.days_until_double || 0) <= 3 ? 'days-warning' : (p.days_until_double <= 7 ? 'days-urgent' : 'days-safe');
        html += `<tr>
            <td>${i+1}</td>
            <td><strong>${p.member_number || 'N/A'}</strong></td>
            <td><strong>${p.jina}</strong> (${p.sauti})</td>
            <td>${badge}</td>
            <td>${p.tukio}</td>
            <td><strong style="color:#dc3545;">TSh ${(p.remaining_amount || p.penalty_amount).toLocaleString()}</strong></td>
            <td class="${daysClass}">${p.days_until_double || 0} siku</td>
            <td><button class="pay-fine-btn" onclick='openFineModal(${p.member_id}, ${p.penalty_id}, "${p.jina.replace(/'/g, "\\'")}", "${p.sauti}", ${p.remaining_amount || p.penalty_amount})'>💰 Lipa</button></td>
        </tr>`;
    }
    tbody.innerHTML = html;
}

// Fine payment
let currentFine = {};

function openFineModal(memberId, penaltyId, name, voice, amount) {
    currentFine = { memberId, penaltyId, name, voice, amount };
    const modalBody = document.getElementById('fineModalBody');
    if (!modalBody) return;
    modalBody.innerHTML = `
        <div style="text-align:center; margin-bottom:20px;">
            <div style="font-size:50px;">💰</div>
            <div><strong>${name}</strong> (${voice})</div>
        </div>
        <div style="background:#f8f9fa; border-radius:16px; padding:15px;">
            <div>Penalty: <strong style="color:#dc3545;">TSh ${amount.toLocaleString()}</strong></div>
        </div>
        <div style="display:flex; gap:12px; margin:20px 0;">
            <button id="fullBtn" style="flex:1; background:#28a745; color:white; padding:12px; border:none; border-radius:40px;" onclick="selectPayFull()">💰 Lipa Kamili</button>
            <button id="partialBtn" style="flex:1; background:#fd7e14; color:white; padding:12px; border:none; border-radius:40px;" onclick="showPartial()">📊 Lipa Sehemu</button>
        </div>
        <div id="partialDiv" style="display:none;"><input type="number" id="partialAmount" placeholder="Kiasi" style="width:100%; padding:12px; margin:10px 0;"></div>
        <input type="text" id="noteInput" placeholder="Maelezo" style="width:100%; padding:12px; margin:10px 0;">
        <button onclick="submitPayment()" style="width:100%; background:#1a2a6e; color:#FFD700; padding:14px; border:none; border-radius:40px;">💾 Thibitisha</button>
    `;
    document.getElementById('finePaymentModal').classList.add('active');
}

function selectPayFull() { document.getElementById('partialDiv').style.display = 'none'; }
function showPartial() { document.getElementById('partialDiv').style.display = 'block'; }

async function submitPayment() {
    const isPartial = document.getElementById('partialDiv').style.display === 'block';
    let amount = isPartial ? parseFloat(document.getElementById('partialAmount').value) : currentFine.amount;
    const note = document.getElementById('noteInput').value || 'Malipo ya penalty';
    if (isNaN(amount) || amount <= 0) { alert('Weka kiasi sahihi'); return; }
    try {
        const response = await fetch('/api/mahudhurio/pay_penalty', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ penalty_id: currentFine.penaltyId, member_id: currentFine.memberId, amount: amount, note: note })
        });
        const result = await response.json();
        if (result.success) { alert(result.message); closeFineModal(); await loadPenaltyList(); location.reload(); }
        else { alert('Error: ' + result.message); }
    } catch(e) { alert('Network error'); }
}

function closeFineModal() { document.getElementById('finePaymentModal').classList.remove('active'); }
function closeModal() { document.getElementById('memberModal').classList.remove('active'); }
function closeSettingsModal() { document.getElementById('settingsModal').classList.remove('active'); }
function closeFrequentModal() { document.getElementById('frequentModal').classList.remove('active'); }

// Voice functions
function toggleVoiceSection(voice) {
    voiceStates[voice] = !voiceStates[voice];
    const section = document.getElementById(`${voice}Section`);
    if (section) section.classList.toggle('hidden');
}

function showAllVoices() {
    for (let v of ['Soprano','Alto','Tenor','Bass']) {
        voiceStates[v] = true;
        const section = document.getElementById(`${v}Section`);
        if (section) section.classList.remove('hidden');
    }
}

function hideAllVoices() {
    for (let v of ['Soprano','Alto','Tenor','Bass']) {
        voiceStates[v] = false;
        const section = document.getElementById(`${v}Section`);
        if (section) section.classList.add('hidden');
    }
}

function searchMembers() {
    const term = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.member-table tbody tr').forEach(row => {
        const name = row.getAttribute('data-name') || '';
        row.style.display = name.includes(term) ? '' : 'none';
    });
}

function resetSearch() {
    document.getElementById('searchInput').value = '';
    document.querySelectorAll('.member-table tbody tr').forEach(row => row.style.display = '');
}

async function updateCurrentEvent() {
    const tukio = document.getElementById('eventSelect').value;
    const tarehe = document.getElementById('eventDate').value;
    await fetch('/api/mahudhurio/event/update', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ tukio, tarehe }) });
    location.reload();
}

async function openSettingsModal() {
    const response = await fetch('/api/mahudhurio/penalty_settings');
    const settings = await response.json();
    const map = {};
    settings.forEach(s => map[s.tukio] = s);
    let html = '<div style="display:grid; gap:10px;">';
    ['Misa','Mazishi','Harusi','Sherehe','Mashindano','Mazoezi','Dominica'].forEach(t => {
        const s = map[t] || { penalty_utoro:20000, penalty_kwa_dakika:1000, siku_za_kudouble:10 };
        html += `<div style="border:1px solid #ddd; padding:10px; border-radius:10px;"><strong>${t}</strong><br>
        Mtoro: <input type="number" id="utoro_${t}" value="${s.penalty_utoro}" style="width:80px;"><br>
        Kwa Dakika: <input type="number" id="dakika_${t}" value="${s.penalty_kwa_dakika}" style="width:80px;"><br>
        Siku Double: <input type="number" id="siku_${t}" value="${s.siku_za_kudouble}" style="width:80px;"><br>
        <button onclick="savePenalty('${t}')">💾 Hifadhi</button></div>`;
    });
    html += '</div><button onclick="closeSettingsModal()" style="margin-top:10px;">✖️ Funga</button>';
    document.getElementById('settingsGrid').innerHTML = html;
    document.getElementById('settingsModal').classList.add('active');
}

async function savePenalty(tukio) {
    const penalty_utoro = document.getElementById(`utoro_${tukio}`).value;
    const penalty_kwa_dakika = document.getElementById(`dakika_${tukio}`).value;
    const siku_za_kudouble = document.getElementById(`siku_${tukio}`).value;
    await fetch('/api/mahudhurio/settings/update', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ tukio, penalty_utoro, penalty_kwa_dakika, siku_za_kudouble }) });
    alert('Imehifadhiwa!');
}

async function viewMemberDetails(id) {
    try {
        const response = await fetch(`/api/mahudhurio/member/${id}`);
        const data = await response.json();
        let html = `<div><strong>${data.member.jina}</strong> (${data.member.sauti})</div><hr>`;
        data.records.forEach(r => {
            html += `<div>📅 ${r.tarehe} - ${r.tukio}: ${r.status} | Penalty: TSh ${r.penalty}</div>`;
        });
        document.getElementById('modalBody').innerHTML = html;
        document.getElementById('memberModal').classList.add('active');
    } catch(e) { alert('Error loading details'); }
}

async function openFrequentOffenders() {
    const response = await fetch('/api/mahudhurio/frequent_offenders');
    const data = await response.json();
    let html = '';
    for (const [voice, offenders] of Object.entries(data.offenders)) {
        if (offenders.length === 0) continue;
        let color = voice === 'Soprano' ? '#FF69B4' : voice === 'Alto' ? '#9370DB' : voice === 'Tenor' ? '#4169E1' : '#2F4F4F';
        html += `<div style="margin-bottom:20px;"><div style="background:${color}; padding:10px; color:white;">🎵 ${voice}</div><table style="width:100%;"><thead><tr><th>#</th><th>Jina</th><th>Mara</th><th>Deni</th></tr></thead><tbody>`;
        offenders.forEach((off, idx) => {
            html += `<tr><td>${idx+1}</td><td>${off.jina}</td><td>${off.offence_count}</td><td>TSh ${off.remaining_debt.toLocaleString()}</td></tr>`;
        });
        html += `</tbody></table></div>`;
    }
    document.getElementById('frequentModalBody').innerHTML = html || '<p>Hakuna wadaiwa</p>';
    document.getElementById('frequentModal').classList.add('active');
}

// Initialize
loadPenaltySettings();
loadPenaltyList();
