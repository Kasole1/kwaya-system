// Teachers list (dynamic)
let teachersList = [
    { id: 1, name: "Peter Massawe", role: "Mwalimu Mkuu", phone: "0745678901", duties: ["Kuongoza mazoezi", "Kufundisha sauti"] },
    { id: 2, name: "Esther Joseph", role: "Mwalimu wa Soprano", phone: "0756789012", duties: ["Kufundisha Soprano", "Kuongoza sehemu"] },
