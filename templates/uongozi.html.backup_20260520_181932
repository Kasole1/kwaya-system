<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    .leadership-container {
        max-width: 100%;
        margin: 0 auto;
        padding: 20px;
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
        border-radius: 24px;
        overflow-x: auto;
    }
    
    .header {
        background: linear-gradient(135deg, #1a2a6e, #2a3a7e);
        padding: 30px;
        border-radius: 20px;
        color: white;
        text-align: center;
        margin-bottom: 40px;
    }
    
    .header h1 {
        color: #FFD700;
        font-size: 32px;
        margin-bottom: 10px;
    }
    
    /* ============ TREE/HIERARCHY STYLES - SCROLLABLE ============ */
    .tree-wrapper {
        overflow-x: auto;
        overflow-y: visible;
        padding: 20px 0;
        margin: 0 -20px;
    }
    
    .tree {
        position: relative;
        display: flex;
        justify-content: center;
        min-width: 1200px;
        padding: 20px;
    }
    
    .tree ul {
        padding-top: 20px;
        position: relative;
        display: flex;
        justify-content: center;
    }
    
    .tree li {
        float: left;
        text-align: center;
        list-style-type: none;
        position: relative;
        padding: 20px 10px 0 10px;
        transition: all 0.3s;
    }
    
    /* Lines connecting nodes */
    .tree li::before, .tree li::after {
        content: '';
        position: absolute;
        top: 0;
        right: 50%;
        border-top: 2px solid #FFD700;
        width: 50%;
        height: 20px;
    }
    
    .tree li::after {
        right: auto;
        left: 50%;
        border-left: 2px solid #FFD700;
    }
    
    .tree li:only-child::after, .tree li:only-child::before {
        display: none;
    }
    
    .tree li:only-child {
        padding-top: 0;
    }
    
    .tree li:first-child::before, .tree li:last-child::after {
        border: none;
    }
    
    .tree li:first-child::after {
        border-radius: 5px 0 0 0;
    }
    
    .tree li:last-child::before {
        border-right: 2px solid #FFD700;
        border-radius: 0 5px 0 0;
    }
    
    .tree .node {
        border: 2px solid #ccc;
        padding: 12px 18px;
        text-decoration: none;
        color: #1a2a6e;
        font-family: 'Times New Roman', Times, serif;
        font-size: 14px;
        font-weight: bold;
        display: inline-block;
        border-radius: 16px;
        transition: all 0.3s;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        min-width: 160px;
        cursor: pointer;
        position: relative;
        z-index: 10;
    }
    
    .tree .node:hover {
        background: linear-gradient(135deg, #FFD700, #FFA500);
        color: #1a2a6e;
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.15);
    }
    
    .tree .node-title {
        font-size: 14px;
        font-weight: bold;
    }
    
    .tree .node-name {
        font-size: 11px;
        color: #666;
        margin-top: 5px;
    }
    
    .tree .node:hover .node-name {
        color: #1a2a6e;
    }
    
    /* Level colors */
    .level-1 .node { background: linear-gradient(135deg, #FFD700, #FFA500); border-color: #1a2a6e; color: #1a2a6e; }
    .level-2 .node { background: linear-gradient(135deg, #1a2a6e, #2a3a7e); color: #FFD700; border-color: #FFD700; }
    .level-2 .node .node-name { color: rgba(255,215,0,0.8); }
    .level-3 .node { background: white; border-color: #1a2a6e; }
    .level-4 .node { background: #f8f9fa; border-color: #17a2b8; }
    
    /* ============ EDIT MODAL STYLES ============ */
    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.8);
        backdrop-filter: blur(5px);
        z-index: 2000;
        justify-content: center;
        align-items: center;
    }
    
    .modal.active {
        display: flex;
    }
    
    .modal-content {
        background: white;
        border-radius: 28px;
        width: 90%;
        max-width: 650px;
        max-height: 90vh;
        overflow-y: auto;
        animation: modalFadeIn 0.3s ease;
    }
    
    @keyframes modalFadeIn {
        from { opacity: 0; transform: scale(0.95) translateY(-20px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }
    
    .modal-header {
        background: linear-gradient(135deg, #1a2a6e, #2a3a7e);
        color: #FFD700;
        padding: 20px 25px;
        border-radius: 28px 28px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .modal-header h2 {
        margin: 0;
        font-size: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .close-modal {
        background: rgba(255,255,255,0.2);
        border: none;
        color: #FFD700;
        font-size: 24px;
        cursor: pointer;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        transition: all 0.2s;
    }
    
    .close-modal:hover {
        background: #FFD700;
        color: #1a2a6e;
        transform: rotate(90deg);
    }
    
    .modal-body {
        padding: 25px;
    }
    
    /* Profile Section */
    .profile-section {
        display: flex;
        gap: 25px;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }
    
    .profile-image {
        text-align: center;
        flex: 0 0 120px;
    }
    
    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #FFD700, #FFA500);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 50px;
        margin-bottom: 10px;
        cursor: pointer;
        transition: all 0.3s;
    }
    
    .profile-avatar:hover {
        transform: scale(1.02);
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }
    
    .profile-image input {
        display: none;
    }
    
    .profile-info {
        flex: 1;
    }
    
    .form-group {
        margin-bottom: 18px;
    }
    
    .form-group label {
        display: block;
        font-weight: bold;
        margin-bottom: 6px;
        color: #1a2a6e;
        font-size: 13px;
    }
    
    .form-group input, .form-group select, .form-group textarea {
        width: 100%;
        padding: 10px 12px;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        font-size: 14px;
        transition: all 0.2s;
    }
    
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
        outline: none;
        border-color: #FFD700;
    }
    
    .btn-save {
        background: linear-gradient(135deg, #28a745, #1e7e34);
        color: white;
        border: none;
        padding: 12px 25px;
        border-radius: 40px;
        cursor: pointer;
        font-weight: bold;
        width: 100%;
        font-size: 16px;
        transition: all 0.3s;
    }
    
    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(40,167,69,0.3);
    }
    
    .duties-list {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 15px;
        margin-top: 15px;
    }
    
    .duty-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #e0e0e0;
    }
    
    .duty-item:last-child {
        border-bottom: none;
    }
    
    .add-duty {
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }
    
    .add-duty input {
        flex: 1;
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 20px;
    }
    
    .add-duty button {
        background: #17a2b8;
        color: white;
        border: none;
        padding: 8px 15px;
        border-radius: 20px;
        cursor: pointer;
    }
    
    @media (max-width: 768px) {
        .tree-wrapper {
            margin: 0;
        }
        .tree {
            min-width: 900px;
        }
        .profile-section {
            flex-direction: column;
            align-items: center;
        }
    }
</style>

