];

// Load data from localStorage
function loadLeadersData() {
    const saved = localStorage.getItem('kwaya_leaders');
    if (saved) {
        const parsed = JSON.parse(saved);
        Object.assign(leadersData, parsed);
    } else {
        leadersData = JSON.parse(JSON.stringify(defaultLeaders));
    }
    
    const savedTeachers = localStorage.getItem('kwaya_teachers_list');
    if (savedTeachers) {
        teachersList = JSON.parse(savedTeachers);
    }
    
    updateDisplayNames();
    renderTeachersTree();
}

function saveLeadersData() {
    localStorage.setItem('kwaya_leaders', JSON.stringify(leadersData));
    updateDisplayNames();
}

function saveTeachersList() {
    localStorage.setItem('kwaya_teachers_list', JSON.stringify(teachersList));
    renderTeachersTree();
}

function updateDisplayNames() {
    for (const [key, data] of Object.entries(leadersData)) {
        const element = document.getElementById(`${key}_name`);
        if (element && data) {
            element.innerText = data.name;
        }
    }
}

function renderTeachersTree() {
    const container = document.getElementById('teachersList');
    if (!container) return;
    
    if (teachersList.length === 0) {
        container.innerHTML = '<li class="level-3"><div class="node" onclick="openAddTeacherModal()">➕ Ongeza Mwalimu</div></li>';
        return;
    }
    
    let html = '';
    teachersList.forEach((teacher, index) => {
        html += `
            <li class="level-3">
                <div class="node" onclick="openTeacherModal(${index})">
                    <div class="node-title">🎓 ${escapeHtml(teacher.role)}</div>
                    <div class="node-name">${escapeHtml(teacher.name)}</div>
                </div>
            </li>
        `;
    });
    
    html += `
        <li class="level-3">
            <div class="node" onclick="openAddTeacherModal()" style="background:#e8f4f8; border-color:#17a2b8;">
                <div class="node-title">➕ Ongeza Mwalimu</div>
                <div class="node-name">Bonyeza kuongeza</div>
            </div>
        </li>
    `;
    
    container.innerHTML = html;
}

function openLeaderModal(key) {
    currentLeaderKey = key;
    const data = leadersData[key] || { name: "", title: "", phone: "", email: "", joinDate: "", bio: "", duties: [] };
    
    document.getElementById('leaderKey').value = key;
    document.getElementById('leaderName').value = data.name || '';
    document.getElementById('leaderTitle').value = data.title || '';
    document.getElementById('leaderPhone').value = data.phone || '';
    document.getElementById('leaderEmail').value = data.email || '';
    document.getElementById('leaderJoinDate').value = data.joinDate || '';
    document.getElementById('leaderBio').value = data.bio || '';
    
    // Set icon based on key
    const iconMap = {
        mwenyekiti: '👑', mwenyekiti_msaidizi: '👔', katibu_mkuu: '📝', katibu_msaidizi: '📋',
        mwalimu_wa_wiki: '📖', mweka_hazina: '💰', mtunza_vifaa: '📦', mhasibu_msaidizi: '🧮',
        mlezi: '🛡️', mwalimu_mkuu: '🎵'
    };
    document.getElementById('modalIcon').innerHTML = iconMap[key] || '👤';
    document.getElementById('modalTitle').innerHTML = `Hariri ${data.title || key}`;
    
    // Render duties
    const dutiesContainer = document.getElementById('dutiesContainer');
    const duties = data.duties || [];
    dutiesContainer.innerHTML = duties.map((duty, idx) => `
        <div class="duty-item">
            <span>• ${escapeHtml(duty)}</span>
            <button type="button" onclick="removeDuty(${idx})" style="background:#dc3545; color:white; border:none; padding:3px 10px; border-radius:15px; cursor:pointer;">✖</button>
        </div>
    `).join('');
    
    // Set avatar if exists
    const avatarDiv = document.getElementById('profileAvatar');
    if (data.avatar) {
        avatarDiv.style.backgroundImage = `url(${data.avatar})`;
        avatarDiv.style.backgroundSize = 'cover';
        avatarDiv.style.backgroundPosition = 'center';
        avatarDiv.innerHTML = '';
    } else {
        avatarDiv.style.backgroundImage = '';
        avatarDiv.innerHTML = '📷';
    }
    
    document.getElementById('leaderModal').classList.add('active');
}

function closeLeaderModal() {
    document.getElementById('leaderModal').classList.remove('active');
}

function addDuty() {
    const newDuty = document.getElementById('newDuty').value.trim();
    if (!newDuty) return;
    
    const data = leadersData[currentLeaderKey] || { duties: [] };
    if (!data.duties) data.duties = [];
    data.duties.push(newDuty);
    leadersData[currentLeaderKey] = data;
    saveLeadersData();
    
    document.getElementById('newDuty').value = '';
    openLeaderModal(currentLeaderKey); // Refresh
}

function removeDuty(index) {
    const data = leadersData[currentLeaderKey];
    if (data && data.duties) {
        data.duties.splice(index, 1);
        saveLeadersData();
        openLeaderModal(currentLeaderKey);
    }
}

function uploadImage() {
    const file = document.getElementById('profileImage').files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            const data = leadersData[currentLeaderKey] || {};
            data.avatar = e.target.result;
            leadersData[currentLeaderKey] = data;
            saveLeadersData();
            
            const avatarDiv = document.getElementById('profileAvatar');
            avatarDiv.style.backgroundImage = `url(${e.target.result})`;
            avatarDiv.style.backgroundSize = 'cover';
            avatarDiv.style.backgroundPosition = 'center';
            avatarDiv.innerHTML = '';
        };
        reader.readAsDataURL(file);
    }
}

// Form submission
document.getElementById('leaderForm').addEventListener('submit', (e) => {
    e.preventDefault();
    
    const key = document.getElementById('leaderKey').value;
    const data = leadersData[key] || {};
    
    data.name = document.getElementById('leaderName').value;
    data.title = document.getElementById('leaderTitle').value;
    data.phone = document.getElementById('leaderPhone').value;
    data.email = document.getElementById('leaderEmail').value;
    data.joinDate = document.getElementById('leaderJoinDate').value;
    data.bio = document.getElementById('leaderBio').value;
    
    leadersData[key] = data;
    saveLeadersData();
    
    alert('✅ Mabadiliko yamehifadhiwa kikamilifu!');
    closeLeaderModal();
});

function openTeacherModal(index) {
    const teacher = teachersList[index];
    if (!teacher) return;
    
    const newName = prompt("Hariri Jina la Mwalimu:", teacher.name);
    if (newName && newName.trim()) {
        teacher.name = newName.trim();
    }
    
    const newRole = prompt("Hariri Wadhifa:", teacher.role);
    if (newRole && newRole.trim()) {
        teacher.role = newRole.trim();
    }
    
    saveTeachersList();
}

function openAddTeacherModal() {
    const name = prompt("Jina la Mwalimu:");
    if (!name) return;
    
    const role = prompt("Wadhifa / Cheo:");
    if (!role) return;
    
    const newId = teachersList.length > 0 ? Math.max(...teachersList.map(t => t.id)) + 1 : 1;
    teachersList.push({
        id: newId,
        name: name,
        role: role,
        phone: "",
        duties: []
    });
    
    saveTeachersList();
    alert('✅ Mwalimu ameongezwa!');
}

function escapeHtml(text) {
    if (!text) return '';
    return String(text).replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
    });
}

// Initialize
loadLeadersData();
</script>
