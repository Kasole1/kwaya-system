<script>
// ============ DATA STORAGE ============
let leadersData = {};
let currentLeaderId = null;
let newLeaderDuties = [];
let newLeaderAvatar = '';

// Load data
function loadLeadersData() {
    const saved = localStorage.getItem('kwaya_leaders_complete');
    if (saved) {
        leadersData = JSON.parse(saved);
    } else {
        document.querySelectorAll('.tree-node').forEach(node => {
            const id = node.getAttribute('data-id');
            if (id) {
                leadersData[id] = {
                    name: node.getAttribute('data-name') || '',
                    title: node.getAttribute('data-title') || '',
                    bio: node.getAttribute('data-bio') || '',
                    phone: node.getAttribute('data-phone') || '',
                    email: node.getAttribute('data-email') || '',
                    duties: [],
                    avatar: ''
                };
            }
        });
        saveLeadersData();
    }
}

function saveLeadersData() {
    localStorage.setItem('kwaya_leaders_complete', JSON.stringify(leadersData));
}

// Open edit modal when clicking on tree node
document.querySelectorAll('.tree-node').forEach(node => {
    node.addEventListener('click', function(e) {
        e.stopPropagation();
        currentLeaderId = this.getAttribute('data-id');
        const data = leadersData[currentLeaderId] || {};
        
        document.getElementById('leaderId').value = currentLeaderId;
        document.getElementById('leaderName').value = data.name || this.getAttribute('data-name');
        document.getElementById('leaderTitle').value = data.title || this.getAttribute('data-title');
        document.getElementById('leaderPhone').value = data.phone || '';
        document.getElementById('leaderEmail').value = data.email || '';
        document.getElementById('leaderBio').value = data.bio || this.getAttribute('data-bio') || '';
        
        const avatarDiv = document.getElementById('profileAvatar');
        if (data.avatar) {
            avatarDiv.innerHTML = `<img src="${data.avatar}" style="width:100%; height:100%; border-radius:50%; object-fit:cover;">`;
        } else {
            avatarDiv.innerHTML = '📷';
            avatarDiv.style.background = 'linear-gradient(135deg, #FFD700, #FFA500)';
        }
        
        renderDuties(data.duties || []);
        document.getElementById('leaderModal').classList.add('active');
    });
});

function renderDuties(duties) {
    const container = document.getElementById('dutiesContainer');
    if (!duties || duties.length === 0) {
        container.innerHTML = '<div style="color:#999; padding:10px; text-align:center;">Hakuna majukumu</div>';
        return;
    }
    container.innerHTML = duties.map((duty, idx) => `
        <div class="duty-item">
            <span>• ${escapeHtml(duty)}</span>
            <button class="remove-duty" onclick="removeDuty(${idx})">✖ Ondoa</button>
        </div>
    `).join('');
}

function addDuty() {
    const duty = document.getElementById('newDuty').value.trim();
    if (!duty) return;
    const data = leadersData[currentLeaderId] || {};
    if (!data.duties) data.duties = [];
    data.duties.push(duty);
    leadersData[currentLeaderId] = data;
    saveLeadersData();
    document.getElementById('newDuty').value = '';
    renderDuties(data.duties);
}

function removeDuty(index) {
    const data = leadersData[currentLeaderId];
    if (data && data.duties) {
        data.duties.splice(index, 1);
        saveLeadersData();
        renderDuties(data.duties);
    }
}

function uploadAvatar() {
    const file = document.getElementById('avatarUpload').files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            const data = leadersData[currentLeaderId] || {};
            data.avatar = e.target.result;
            leadersData[currentLeaderId] = data;
            saveLeadersData();
            document.getElementById('profileAvatar').innerHTML = `<img src="${e.target.result}" style="width:100%; height:100%; border-radius:50%; object-fit:cover;">`;
        };
        reader.readAsDataURL(file);
    }
}

function saveLeaderData() {
    const data = leadersData[currentLeaderId] || {};
    data.name = document.getElementById('leaderName').value;
    data.title = document.getElementById('leaderTitle').value;
    data.phone = document.getElementById('leaderPhone').value;
    data.email = document.getElementById('leaderEmail').value;
    data.bio = document.getElementById('leaderBio').value;
    leadersData[currentLeaderId] = data;
    saveLeadersData();
    
    // Update tree node
    const node = document.querySelector(`.tree-node[data-id="${currentLeaderId}"]`);
    if (node) {
        const nameDiv = node.querySelector('.tree-node-name');
        if (nameDiv) nameDiv.innerText = data.name;
        node.setAttribute('data-name', data.name);
        node.setAttribute('data-title', data.title);
        node.setAttribute('data-bio', data.bio);
        node.setAttribute('data-phone', data.phone);
        node.setAttribute('data-email', data.email);
    }
    
    alert('✅ Mabadiliko yamehifadhiwa!');
    closeLeaderModal();
}

function closeLeaderModal() {
    document.getElementById('leaderModal').classList.remove('active');
}

// ============ ADD NEW LEADER ============
function openAddLeaderModal() {
    document.getElementById('newLeaderName').value = '';
    document.getElementById('newLeaderTitle').value = '';
    document.getElementById('newLeaderPhone').value = '';
    document.getElementById('newLeaderEmail').value = '';
    document.getElementById('newLeaderBio').value = '';
    document.getElementById('newLeaderParent').value = '';
    newLeaderDuties = [];
    newLeaderAvatar = '';
    document.getElementById('newProfileAvatar').innerHTML = '📷';
    renderNewDuties();
    document.getElementById('addLeaderModal').classList.add('active');
}

function closeAddLeaderModal() {
    document.getElementById('addLeaderModal').classList.remove('active');
}

function uploadNewAvatar() {
    const file = document.getElementById('newAvatarUpload').files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            newLeaderAvatar = e.target.result;
            document.getElementById('newProfileAvatar').innerHTML = `<img src="${e.target.result}" style="width:100%; height:100%; border-radius:50%; object-fit:cover;">`;
        };
        reader.readAsDataURL(file);
    }
}

function addNewDuty() {
    const duty = document.getElementById('newDutyInput').value.trim();
    if (!duty) return;
    newLeaderDuties.push(duty);
    renderNewDuties();
    document.getElementById('newDutyInput').value = '';
}

function renderNewDuties() {
    const container = document.getElementById('newDutiesContainer');
    if (newLeaderDuties.length === 0) {
        container.innerHTML = '<div style="color:#999; padding:10px; text-align:center;">Hakuna majukumu</div>';
        return;
    }
    container.innerHTML = newLeaderDuties.map((duty, idx) => `
        <div class="duty-item">
            <span>• ${escapeHtml(duty)}</span>
            <button class="remove-duty" onclick="removeNewDuty(${idx})">✖ Ondoa</button>
        </div>
    `).join('');
}

function removeNewDuty(index) {
    newLeaderDuties.splice(index, 1);
    renderNewDuties();
}

function saveNewLeader() {
    const name = document.getElementById('newLeaderName').value.trim();
    const title = document.getElementById('newLeaderTitle').value.trim();
    const parentId = document.getElementById('newLeaderParent').value;
    
    if (!name || !title) {
        alert('Tafadhali jaza jina na wadhifa');
        return;
    }
    if (!parentId) {
        alert('Tafadhali chagua nafasi ya kiongozi');
        return;
    }
    
    const newId = parentId + '_' + Date.now();
    leadersData[newId] = {
        name: name,
        title: title,
        phone: document.getElementById('newLeaderPhone').value,
        email: document.getElementById('newLeaderEmail').value,
        bio: document.getElementById('newLeaderBio').value,
        duties: newLeaderDuties,
        avatar: newLeaderAvatar,
        joinDate: new Date().toISOString().split('T')[0]
    };
    saveLeadersData();
    
    alert(`✅ Kiongozi "${name}" ameongezwa! Tafadhali refresh page.`);
    closeAddLeaderModal();
    location.reload();
}

function escapeHtml(text) {
    if (!text) return '';
    return String(text).replace(/[&<>]/g, m => m === '&' ? '&amp;' : (m === '<' ? '&lt;' : '&gt;'));
}

// Initialize
loadLeadersData();

// Close modal on outside click
window.onclick = function(event) {
    if (event.target.classList.contains('modal')) {
        event.target.classList.remove('active');
    }
}
</script>
{% endblock %}
