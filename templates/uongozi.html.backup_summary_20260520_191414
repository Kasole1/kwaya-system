{% extends "base.html" %}

{% block title %}Uongozi - Kwaya Mt. Bonifasi{% endblock %}

{% block content %}
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    .leadership-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }
    
    .leadership-header {
        background: linear-gradient(135deg, #1a2a6e, #2a3a7e);
        padding: 25px 30px;
        border-radius: 20px;
        color: white;
        margin-bottom: 25px;
        text-align: center;
    }
    
    .leadership-header h1 {
        color: #FFD700;
        margin: 0;
        font-size: 28px;
    }
    
    .tree-section {
        background: white;
        border-radius: 24px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        border-top: 5px solid #FFD700;
        margin-bottom: 30px;
    }
    
    .tree-title {
        font-size: 22px;
        color: #1a2a6e;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #FFD700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .tree-wrapper {
        overflow-x: auto;
        padding: 20px 0;
    }
    
    .tree {
        min-width: 1300px;
        width: max-content;
        padding: 20px;
        background: linear-gradient(135deg, #f8f9fa, #fff);
        border-radius: 20px;
    }
    
    .tree ul {
        padding-top: 20px;
        position: relative;
        display: flex;
        justify-content: center;
        flex-wrap: nowrap;
        list-style: none;
    }
    
    .tree li {
        float: left;
        text-align: center;
        list-style-type: none;
        position: relative;
        padding: 20px 15px 0 15px;
    }
    
    .tree li::before, .tree li::after {
        content: '';
        position: absolute;
        top: 0;
        right: 50%;
        border-top: 2px solid #FFD700;
        width: 50%;
        height: 20px;
    }
    
    .tree li::after {
        right: auto;
        left: 50%;
        border-left: 2px solid #FFD700;
    }
    
    .tree li:only-child::after, .tree li:only-child::before {
        display: none;
    }
    
    .tree li:first-child::before, .tree li:last-child::after {
        border: none;
    }
    
    .tree-node {
        border: 2px solid #ccc;
        padding: 12px 18px;
        display: inline-block;
        border-radius: 16px;
        transition: all 0.3s;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        min-width: 170px;
        cursor: pointer;
    }
    
    .tree-node:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.15);
    }
    
    .tree-node-title {
        font-size: 14px;
        font-weight: bold;
    }
    
    .tree-node-name {
        font-size: 11px;
        color: #666;
        margin-top: 5px;
    }
    
    .level-1 .tree-node { background: linear-gradient(135deg, #FFD700, #FFA500); border-color: #1a2a6e; }
    .level-2 .tree-node { background: linear-gradient(135deg, #1a2a6e, #2a3a7e); color: #FFD700; border-color: #FFD700; }
    .level-3 .tree-node { background: white; border-color: #17a2b8; }
    .level-4 .tree-node { background: #f8f9fa; border-color: #6c757d; }
    
    .scroll-hint {
        text-align: center;
        margin-top: 15px;
        color: #888;
        font-size: 12px;
    }
    
    /* Modal Styles */
    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.85);
        backdrop-filter: blur(8px);
        z-index: 2000;
        justify-content: center;
        align-items: center;
    }
    
    .modal.active {
        display: flex;
    }
    
    .modal-content {
        background: white;
        border-radius: 28px;
        width: 90%;
        max-width: 550px;
        max-height: 90vh;
        overflow-y: auto;
    }
    
    .modal-header {
        background: linear-gradient(135deg, #1a2a6e, #2a3a7e);
        color: #FFD700;
        padding: 20px 25px;
        border-radius: 28px 28px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .close-modal {
        background: rgba(255,255,255,0.2);
        border: none;
        color: #FFD700;
        font-size: 24px;
        cursor: pointer;
        width: 38px;
        height: 38px;
        border-radius: 50%;
    }
    
    .modal-body {
        padding: 25px;
    }
    
    .profile-section {
        display: flex;
        gap: 20px;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }
    
    .profile-avatar-container {
        text-align: center;
        flex: 0 0 120px;
    }
    
    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #FFD700, #FFA500);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 50px;
        cursor: pointer;
        overflow: hidden;
        margin-bottom: 8px;
    }
    
    .profile-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    
    .form-group {
        margin-bottom: 18px;
    }
    
    .form-group label {
        display: block;
        font-weight: bold;
        margin-bottom: 6px;
        color: #1a2a6e;
        font-size: 13px;
    }
    
    .form-group input, .form-group select, .form-group textarea {
        width: 100%;
        padding: 10px 12px;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        font-size: 14px;
    }
    
    .duties-section {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 15px;
        margin: 15px 0;
    }
    
    .duties-title {
        font-weight: bold;
        color: #1a2a6e;
        margin-bottom: 10px;
    }
    
    .duty-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #e0e0e0;
    }
    
    .remove-duty {
        background: #dc3545;
        color: white;
        border: none;
        padding: 3px 10px;
        border-radius: 20px;
        cursor: pointer;
    }
    
    .add-duty {
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }
    
    .add-duty input {
        flex: 1;
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 20px;
    }
    
    .add-duty button {
        background: #28a745;
        color: white;
        border: none;
        padding: 8px 15px;
        border-radius: 20px;
        cursor: pointer;
    }
    
    .btn-save {
        background: linear-gradient(135deg, #28a745, #1e7e34);
        color: white;
        border: none;
        padding: 14px;
        width: 100%;
        border-radius: 40px;
        font-weight: bold;
        font-size: 16px;
        cursor: pointer;
        margin-top: 10px;
    }
    
    @media (max-width: 768px) {
        .tree-node { min-width: 130px; padding: 8px 12px; }
        .tree-node-title { font-size: 11px; }
        .profile-section { flex-direction: column; align-items: center; }
    }
</style>

