    <!-- BASS SECTION -->
<div id="BassSection" class="voice-section voice-section-bass">
    <div class="voice-header voice-bass">🎵 BASS <span id="bassCount">{{ bass|length }}</span></div>
    <table class="member-table">
        <thead>
            <tr>
                <th>SN</th>
                <th>MEMBER #</th>
                <th>JINA</th>
                <th>MAHUDHURIO</th>
                <th>STATUS</th>
                <th>DAKIKA</th>
                <th>PENALTY (TSh)</th>
                <th>VIEW</th>
            </tr>
        </thead>
        <tbody>
            {% for member in bass %}
            {% set prefix = {'Soprano': 'S', 'Alto': 'A', 'Tenor': 'T', 'Bass': 'B'} %}
            {% set member_number = prefix[member.sauti] ~ '%03d'|format(loop.index) %}
            <tr data-name="{{ member.jina|lower }}" data-id="{{ member.id }}">
                <td>{{ loop.index }}</td>
                <td><strong style="color: #1a2a6e; font-family: monospace;">{{ member_number }}</strong></td>
                <td>{{ member.jina }}</td>
                <td><div class="toggle-switch" data-id="{{ member.id }}" data-status="present" onclick="toggleStatus({{ member.id }}, '{{ member.jina }}', 'Bass')"></div></td>
                <td class="status-cell-{{ member.id }}">-</td>
                <td class="minutes-cell-{{ member.id }}"><div class="minutes-control" style="display: none;"><button class="minutes-btn" onclick="changeMinutes({{ member.id }}, -1)">-</button><span class="minutes-value" id="minutes-{{ member.id }}">0</span><button class="minutes-btn" onclick="changeMinutes({{ member.id }}, 1)">+</button></div></td>
                <td class="penalty-cell-{{ member.id }}">0</td>
                <td><button class="view-details-btn" onclick="viewMemberDetails({{ member.id }})">👁️ Taarifa</button></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<!-- Member Details Modal -->
<div id="memberModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalTitle">👤 Taarifa za Mwanakwaya</h2>
            <button class="close-modal" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body" id="modalBody">
            <div style="text-align: center; padding: 30px;">Loading...</div>
        </div>
    </div>
</div>

<!-- Settings Modal -->
<div id="settingsModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>⚙️ Penalty Settings</h2>
            <button class="close-modal" onclick="closeSettingsModal()">&times;</button>
        </div>
        <div class="modal-body">
            <div class="settings-grid" id="settingsGrid"></div>
        </div>
    </div>
</div>

<script>
    let currentTukio = '{{ current_event.tukio }}';
    let penaltySettingsCache = {};
    
    // Load penalty settings on page load
    async function loadPenaltySettings() {
        const response = await fetch('/api/mahudhurio/penalty_settings');
        const settings = await response.json();
        for (const s of settings) {
            penaltySettingsCache[s.tukio] = s;
        }
        showPenaltyInfo();
    }
    
    function showPenaltyInfo() {
        const selectedTukio = document.getElementById('eventSelect').value;
        const setting = penaltySettingsCache[selectedTukio] || { penalty_utoro: 20000, penalty_kwa_dakika: 1000, siku_za_kudouble: 10 };
        
        const doubleAmount = setting.penalty_utoro * 2;
        const lateAmountPerMin = setting.penalty_kwa_dakika;
        
        const infoHtml = `
            <div style="display: flex; gap: 15px; flex-wrap: wrap; align-items: center;">
                <span>💰 <strong>${selectedTukio}</strong></span>
                <span>❌ Mtoro: <strong>TSh ${parseInt(setting.penalty_utoro).toLocaleString()}</strong></span>
                <span>⏱️ Dakika: <strong>TSh ${parseInt(setting.penalty_kwa_dakika).toLocaleString()}</strong>/dakika</span>
                <span>⚠️ Baada ya siku ${setting.siku_za_kudouble}: <strong>TSh ${doubleAmount.toLocaleString()}</strong></span>
                <span>🚫 Baada ya siku 30: <strong style="color: #dc3545;">Kusimamishwa kwa miezi 3</strong></span>
            </div>
        `;
        
        const infoDiv = document.getElementById('penaltyInfoDisplay');
        infoDiv.innerHTML = infoHtml;
        infoDiv.style.display = 'block';
    }
    
    function showNotification(message, type = 'info') {
        const toast = document.createElement('div');
        toast.className = 'penalty-toast';
        toast.innerHTML = message;
        document.body.appendChild(toast);
        setTimeout(() => {
            toast.style.animation = 'slideInRight 0.3s reverse';
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    }
    
    function toggleStatus(id, name, sauti) {
        const toggle = document.querySelector(`.toggle-switch[data-id="${id}"]`);
        const currentStatus = toggle.dataset.status;
        let newStatus, statusText, colorClass;
        
        if (currentStatus === 'present') { newStatus = 'absent'; statusText = 'Mtoro'; colorClass = 'active-red'; }
        else if (currentStatus === 'absent') { newStatus = 'late'; statusText = 'Amechelewa'; colorClass = 'active-yellow'; }
        else if (currentStatus === 'late') { newStatus = 'permission'; statusText = 'Ruhusa'; colorClass = 'active-purple'; }
        else { newStatus = 'present'; statusText = 'Amehudhuria'; colorClass = 'active-green'; }
        
        toggle.dataset.status = newStatus;
        toggle.className = `toggle-switch ${colorClass}`;
        document.querySelector(`.status-cell-${id}`).innerHTML = `<span class="status-${newStatus}">${statusText}</span>`;
        
        const minutesControl = document.querySelector(`.minutes-cell-${id} .minutes-control`);
        if (newStatus === 'late') {
            minutesControl.style.display = 'flex';
        } else {
            minutesControl.style.display = 'none';
            if (newStatus !== 'late') {
                document.getElementById(`minutes-${id}`).innerText = '0';
                updatePenalty(id, newStatus, 0, name, sauti);
            }
        }
        
        if (newStatus === 'late') {
            const minutes = parseInt(document.getElementById(`minutes-${id}`).innerText);
            updatePenalty(id, newStatus, minutes, name, sauti);
        } else if (newStatus !== 'late') {
            updatePenalty(id, newStatus, 0, name, sauti);
        }
    }
    
    function changeMinutes(id, delta) {
        const minutesSpan = document.getElementById(`minutes-${id}`);
        let minutes = parseInt(minutesSpan.innerText) + delta;
        if (minutes < 0) minutes = 0;
        if (minutes > 120) minutes = 120;
        minutesSpan.innerText = minutes;
        const toggle = document.querySelector(`.toggle-switch[data-id="${id}"]`);
        if (toggle.dataset.status === 'late') {
            updatePenalty(id, 'late', minutes, null, null);
        }
    }
    
    async function updatePenalty(id, status, minutes, name, sauti) {
        const tukio = document.getElementById('eventSelect').value;
        const response = await fetch('/api/mahudhurio/update', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ member_id: id, status: status, dakika_chelewa: minutes, tukio: tukio, member_name: name, sauti: sauti })
        });
        const data = await response.json();
        if (data.success) {
            document.querySelector(`.penalty-cell-${id}`).innerHTML = `<span class="penalty-amount">${data.penalty.toLocaleString()}</span>`;
        }
    }
    
    async function updateCurrentEvent() {
        const tukio = document.getElementById('eventSelect').value;
        const tarehe = document.getElementById('eventDate').value;
        const response = await fetch('/api/mahudhurio/event/update', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tukio: tukio, tarehe: tarehe })
        });
        if (response.ok) {
            document.getElementById('currentEventDisplay').innerHTML = `🎯 Tukio la Sasa: ${tukio} | 📅 ${tarehe}`;
            currentTukio = tukio;
            showNotification(`✅ Tukio limebadilishwa kuwa ${tukio}! Penalty: Mtoro TSh ${penaltySettingsCache[tukio]?.penalty_utoro?.toLocaleString() || '20,000'}`, 'success');
            setTimeout(() => location.reload(), 1500);
        }
    }
    
    async function viewMemberDetails(id) {
        console.log("Fetching details for ID:", id);
        try {
            const response = await fetch(`/api/mahudhurio/member/${id}`);
            const data = await response.json();
            console.log("Data received:", data);
            
            if (data.success) {
                let recordsHtml = '';
                for (const rec of data.records) {
                    let statusClass = rec.status === 'present' ? 'status-present' : (rec.status === 'absent' ? 'status-absent' : (rec.status === 'late' ? 'status-late' : 'status-permission'));
                    let statusText = rec.status === 'present' ? '✅ Amehudhuria' : (rec.status === 'absent' ? '❌ Mtoro' : (rec.status === 'late' ? '⚠️ Amechelewa' : '📝 Ruhusa'));
                    let statusIcon = rec.status === 'present' ? '✅' : (rec.status === 'absent' ? '❌' : (rec.status === 'late' ? '⚠️' : '📝'));
                    let badgeColor = rec.status === 'present' ? '#28a745' : (rec.status === 'absent' ? '#dc3545' : (rec.status === 'late' ? '#fd7e14' : '#9b59b6'));
                    
                    recordsHtml += `
                        <div style="background: white; border-radius: 14px; padding: 14px; margin-bottom: 12px; border-left: 4px solid ${badgeColor}; box-shadow: 0 2px 8px rgba(0,0,0,0.04);">
                            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; margin-bottom: 8px;">
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <strong style="color: #1a2a6e;">📅 ${rec.tarehe}</strong>
                                    <span class="${statusClass}" style="background: ${badgeColor}20; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: bold;">${statusIcon} ${statusText}</span>
                                </div>
                                <span style="background: #f0f0f0; padding: 4px 10px; border-radius: 20px; font-size: 11px;">${rec.tukio}</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; margin-top: 8px;">
                                <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                                    ${rec.dakika_chelewa > 0 ? `<span style="font-size: 12px; color: #fd7e14;">⏱️ Chelewa: ${rec.dakika_chelewa} dakika</span>` : ''}
                                    <span style="font-size: 13px; font-weight: bold; color: #dc3545;">💰 Penalty: TSh ${(rec.penalty || 0).toLocaleString()}</span>
                                </div>
                                ${!rec.imelipwa ? 
                                    `<button onclick="payPenalty(${rec.id})" style="background: linear-gradient(135deg, #28a745, #1e7e34); color: white; border: none; padding: 6px 16px; border-radius: 25px; cursor: pointer; font-size: 11px; font-weight: bold;">💰 Lipa Sasa</button>` : 
                                    `<span style="background: #28a74520; color: #28a745; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: bold;">✓ IMELIPWA</span>`
                                }
                            </div>
                            ${rec.tarehe_penalty_double ? `<div style="margin-top: 8px; font-size: 10px; color: #888;">📅 Double penalty date: ${rec.tarehe_penalty_double}</div>` : ''}
                        </div>
                    `;
                }
                
                const totalPenalty = data.total_penalty || 0;
                const daysSince = data.days_since_last_penalty || 0;
                const recordsCount = data.records?.length || 0;
                
                const suspendWarning = data.should_be_suspended ? 
                    `<div style="background: linear-gradient(135deg, #dc3545, #c82333); color: white; padding: 16px; border-radius: 16px; margin-bottom: 20px; text-align: center; display: flex; align-items: center; justify-content: center; gap: 10px;">
                        <span style="font-size: 24px;">⚠️</span>
                        <span style="font-weight: bold;">MWANAKWAYA AMESIMAMISHWA KWA MIEZI 3! Penalty isiyolipwa kwa siku 30+</span>
                    </div>` : '';
                
                const modalContent = `
                    <div style="background: linear-gradient(135deg, #1a2a6e, #2a3a7e); margin: -25px -25px 20px -25px; padding: 25px; border-radius: 25px 25px 0 0;">
                        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
                            <div style="display: flex; align-items: center; gap: 15px;">
                                <div style="background: #FFD700; width: 55px; height: 55px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px;">🎵</div>
                                <div>
                                    <h3 style="color: #FFD700; margin: 0; font-size: 20px;">${escapeHtml(data.member.jina)}</h3>
                                    <p style="color: white; margin: 5px 0 0; font-size: 13px;">${data.member.sauti} • Member #${data.member.id}</p>
                                </div>
                            </div>
                            <div style="background: ${data.member.status === 'suspended' ? '#dc3545' : '#28a745'}; padding: 6px 18px; border-radius: 30px; font-size: 12px; font-weight: bold; color: white;">
                                ${data.member.status === 'suspended' ? '⏸️ SIMAMISHWA MIEZI 3' : '✅ ACTIVE'}
                            </div>
                        </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 25px;">
                        <div style="background: linear-gradient(135deg, #dc3545, #c82333); padding: 15px; border-radius: 16px; text-align: center;">
                            <div style="font-size: 11px; color: white; opacity: 0.8;">JUMLA YA PENALTY</div>
                            <div style="font-size: 22px; font-weight: bold; color: #FFD700;">TSh ${totalPenalty.toLocaleString()}</div>
                        </div>
                        <div style="background: linear-gradient(135deg, #fd7e14, #e67e22); padding: 15px; border-radius: 16px; text-align: center;">
                            <div style="font-size: 11px; color: white; opacity: 0.8;">SIKU TANGU PENALTY</div>
                            <div style="font-size: 28px; font-weight: bold; color: white;">${daysSince}</div>
                            <div style="font-size: 10px; color: white;">siku zilizopita</div>
                            ${daysSince >= 30 ? `<div style="font-size: 10px; color: #FFD700; margin-top: 5px;">⚠️ Inastahili kusimamishwa</div>` : ''}
                        </div>
                        <div style="background: linear-gradient(135deg, #17a2b8, #138496); padding: 15px; border-radius: 16px; text-align: center;">
                            <div style="font-size: 11px; color: white; opacity: 0.8;">JUMLA YA MAHUDHURIO</div>
                            <div style="font-size: 28px; font-weight: bold; color: white;">${recordsCount}</div>
                            <div style="font-size: 10px; color: white;">rekodi zilizorekodiwa</div>
                        </div>
                    </div>
                    
                    ${suspendWarning}
                    
                    <div style="display: flex; justify-content: space-between; align-items: center; margin: 20px 0 15px 0;">
                        <h4 style="color: #1a2a6e; margin: 0; border-left: 4px solid #FFD700; padding-left: 12px;">📋 HISTORIA YA MAHUDHURIO</h4>
                        <span style="font-size: 11px; color: #888;">${recordsCount} rekodi</span>
                    </div>
                    <div style="max-height: 350px; overflow-y: auto; padding-right: 5px;">
                        ${recordsHtml || '<div style="text-align: center; padding: 40px; color: #999; background: #f8f9fa; border-radius: 16px;">📭 Hakuna rekodi za mahudhurio</div>'}
                    </div>
                `;
                
                document.getElementById('modalTitle').innerHTML = `👤 ${escapeHtml(data.member.jina)} - ${escapeHtml(data.member.sauti)}`;
                document.getElementById('modalBody').innerHTML = modalContent;
                document.getElementById('memberModal').classList.add('active');
            } else {
                alert('Hakuna taarifa za mwanakwaya huyu');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Kuna tatizo la kupata taarifa. Tafadhali jaribu tena.');
        }
    }
    
    function escapeHtml(text) {
        if (!text) return '';
        return text.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
    
    async function payPenalty(id) {
        const response = await fetch(`/api/mahudhurio/pay/${id}`, { method: 'POST' });
        if (response.ok) { 
            showNotification('✅ Penalty imelipwa kikamilifu!', 'success');
            setTimeout(() => location.reload(), 1500);
        } else {
            showNotification('❌ Kuna tatizo, jaribu tena!', 'error');
        }
    }
    
    function closeModal() { 
        document.getElementById('memberModal').classList.remove('active'); 
    }
    
    async function openSettingsModal() {
        const response = await fetch('/api/mahudhurio/penalty_settings');
        const settings = await response.json();
        const settingsMap = {};
        for (const s of settings) { settingsMap[s.tukio] = s; }
        const tukioList = ['Misa', 'Mazishi', 'Harusi', 'Sherehe', 'Mashindano', 'Mazoezi', 'Dominica'];
        const icons = { 'Misa':'⛪', 'Mazishi':'🕯️', 'Harusi':'💍', 'Sherehe':'🎉', 'Mashindano':'🏆', 'Mazoezi':'🎵', 'Dominica':'📖' };
        let html = `<div class="settings-modern"><h3>⚙️ <span style="color:white;">MPANGILIO WA PENALTI</span></h3><div class="subtitle">Weka viwango vya penalty kwa kila aina ya tukio</div><div class="settings-compact-grid">`;
        for (const tukio of tukioList) {
            const setting = settingsMap[tukio] || { penalty_utoro: 20000, penalty_kwa_dakika: 1000, siku_za_kudouble: 10 };
            html += `<div class="compact-setting-card"><div class="compact-event-header"><span class="compact-event-icon">${icons[tukio]}</span><span class="compact-event-name">${tukio}</span></div>
            <div class="compact-input-group"><label>💰 MTORO</label><input type="number" id="utoro_${tukio}" value="${setting.penalty_utoro}"></div>
            <div class="compact-input-group"><label>⏱️ KWA DAKIKA</label><input type="number" id="dakika_${tukio}" value="${setting.penalty_kwa_dakika}"></div>
            <div class="compact-input-group"><label>📅 SIKU ZA DOUBLE</label><input type="number" id="siku_${tukio}" value="${setting.siku_za_kudouble}"></div>
            <button class="compact-save-btn" onclick="saveSinglePenalty('${tukio}')">💾 HIFADHI</button></div>`;
        }
        html += `</div><div class="settings-summary"><div class="summary-item">📊 <strong>${tukioList.length}</strong> Aina za Matukio</div><div class="summary-item">💰 Penalty huongezeka mara mbili baada ya siku ${settingsMap[Object.keys(settingsMap)[0]]?.siku_za_kudouble || 10}</div><div class="summary-item">🚫 Kusimamishwa baada ya siku 30</div><button class="settings-close" onclick="closeSettingsModal()">✖️ FUNGA</button></div></div>`;
        document.getElementById('settingsGrid').innerHTML = html;
        document.getElementById('settingsModal').classList.add('active');
    }
    
    async function saveSinglePenalty(tukio) {
        const penalty_utoro = document.getElementById(`utoro_${tukio}`).value;
        const penalty_kwa_dakika = document.getElementById(`dakika_${tukio}`).value;
        const siku_za_kudouble = document.getElementById(`siku_${tukio}`).value;
        const response = await fetch('/api/mahudhurio/settings/update', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tukio, penalty_utoro, penalty_kwa_dakika, siku_za_kudouble })
        });
        if (response.ok) {
            const btn = event.target;
            const originalText = btn.innerHTML;
            btn.innerHTML = '✅ IMEFANIKIWA';
            btn.style.background = '#28a745';
            setTimeout(() => { btn.innerHTML = originalText; btn.style.background = 'linear-gradient(135deg, #FFD700 0%, #FFA500 100%)'; }, 1500);
            showNotification(`✅ Settings za ${tukio} zimehifadhiwa!`, 'success');
            loadPenaltySettings();
        } else { 
            showNotification('❌ Kuna tatizo, tafadhali jaribu tena!', 'error');
        }
    }
    
    function closeSettingsModal() { 
        document.getElementById('settingsModal').classList.remove('active'); 
    }
    
    let voiceStates = { Soprano: true, Alto: true, Tenor: true, Bass: true };
    
    function toggleVoiceSection(voice) {
        voiceStates[voice] = !voiceStates[voice];
        const section = document.getElementById(`${voice}Section`);
        const btn = document.querySelector(`.voice-toggle[data-voice="${voice}"]`);
        if (section) {
            if (voiceStates[voice]) { 
                section.classList.remove('hidden'); 
                if (btn) btn.classList.add('active'); 
            } else { 
                section.classList.add('hidden'); 
                if (btn) btn.classList.remove('active'); 
            }
        }
    }
    
    function showAllVoices() { 
        for (const voice of ['Soprano','Alto','Tenor','Bass']) { 
            voiceStates[voice]=true; 
            const s=document.getElementById(`${voice}Section`); 
            const b=document.querySelector(`.voice-toggle[data-voice="${voice}"]`); 
            if(s) s.classList.remove('hidden'); 
            if(b) b.classList.add('active'); 
        } 
    }
    
    function hideAllVoices() { 
        for (const voice of ['Soprano','Alto','Tenor','Bass']) { 
            voiceStates[voice]=false; 
            const s=document.getElementById(`${voice}Section`); 
            const b=document.querySelector(`.voice-toggle[data-voice="${voice}"]`); 
            if(s) s.classList.add('hidden'); 
            if(b) b.classList.remove('active'); 
        } 
    }
    
    function searchMembers() { 
        const term = document.getElementById('searchInput').value.toLowerCase(); 
        document.querySelectorAll('.member-table tbody tr').forEach(row => { 
            const name = row.getAttribute('data-name') || ''; 
            row.style.display = name.includes(term) ? '' : 'none'; 
        }); 
    }
    
    function resetSearch() { 
        document.getElementById('searchInput').value = ''; 
        document.querySelectorAll('.member-table tbody tr').forEach(row => { 
            row.style.display = ''; 
        }); 
    }
    
    // Initialize
    loadPenaltySettings();
</script>
{% endblock %}