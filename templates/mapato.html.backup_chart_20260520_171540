<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
let incomeSources = [];
let incomeRecords = [];
let pieChart = null;
let barChart = null;
let currentYear = {{ current_year if current_year else 2026 }};
let globalTarget = 10000000; // Default TSh 10M

async function loadIncomeData() {
    try {
        // Load mapato data
        const response = await fetch('/api/mapato/data?mwaka=' + currentYear);
        const data = await response.json();
        console.log("Mapato data loaded:", data);
        
        if (data.success) {
            // Filter out inventory sources from the sources list
            const inventorySourceIds = [5, 6, 7]; // IDs za inventory sources
            incomeSources = (data.sources || []).filter(s => !inventorySourceIds.includes(s.id));
            incomeRecords = data.records || [];
            globalTarget = data.global_target || 10000000;
            
            // Also load inventory sales separately
            await loadInventorySales();
            
            renderAll();
        }
    } catch(e) {
        console.error("Error loading data:", e);
    }
}

async function loadInventorySales() {
    console.log("Loading inventory sales...");
    try {
        const response = await fetch('/api/sales');
        const data = await response.json();
        console.log("Sales API response:", data);
        
        if (data.success) {
            const sales = data.sales || [];
            const totalInventory = sales.reduce((sum, sale) => sum + (sale.total_amount || 0), 0);
            console.log("Total inventory sales amount:", totalInventory);
            
            // Add or update inventory record
            const existingIndex = incomeRecords.findIndex(r => r.source_id === 999);
            if (totalInventory > 0) {
                const inventoryRecord = {
                    source_id: 999,
                    source_name: "📦 Inventory (Mauzo ya Bidhaa)",
                    amount: totalInventory,
                    date: new Date().toISOString().split('T')[0],
                    note: "Mapato ya jumla kutoka inventory"
                };
                
                if (existingIndex >= 0) {
                    incomeRecords[existingIndex] = inventoryRecord;
                } else {
                    incomeRecords.push(inventoryRecord);
                }
                console.log("Inventory record added/updated");
            } else if (existingIndex >= 0) {
                // Keep the record even if zero? Remove to hide when zero
                incomeRecords.splice(existingIndex, 1);
                console.log("Inventory record removed (zero sales)");
            }
        }
    } catch(e) {
        console.error("Error loading inventory sales:", e);
    }
}

function loadDefaultData() {
    incomeSources = [
        { id: 1, name: "Ada za Kwaya", color: "#1a2a6e", target: 5000000, description: "Ada za kila mwezi", icon: "💰" },
        { id: 2, name: "Penalty", color: "#dc3545", target: 2000000, description: "Faini za kutokuhudhuria", icon: "⚠️" },
        { id: 3, name: "Wafadhili", color: "#28a745", target: 3000000, description: "Michango ya wafadhili", icon: "🤝" },
        { id: 4, name: "Mauzo", color: "#17a2b8", target: 2000000, description: "Mauzo ya vifaa", icon: "👕" }
    ];
    
    const today = new Date();
    incomeRecords = [];
    for (let i = 0; i < 10; i++) {
        const source = incomeSources[Math.floor(Math.random() * incomeSources.length)];
        const date = new Date(today);
        date.setDate(today.getDate() - Math.floor(Math.random() * 90));
        incomeRecords.push({
            id: i + 1,
            source_id: source.id,
            source_name: source.name,
            amount: Math.floor(Math.random() * 300000) + 10000,
            date: date.toISOString().split('T')[0],
            note: `Mapato kutoka ${source.name}`
        });
    }
    renderAll();
}

function renderAll() {
    renderSourcesGrid();
    updateSummaryStats();
    updateCharts();
}

function renderSourcesGrid() {
    const grid = document.getElementById('sourcesGrid');
    if (!grid) return;
    
    console.log("Rendering sources grid...");
    
    const total = incomeRecords.reduce((sum, r) => sum + (r.amount || 0), 0);
    const sourceTotals = {};
    incomeRecords.forEach(r => { sourceTotals[r.source_id] = (sourceTotals[r.source_id] || 0) + (r.amount || 0); });
    
    console.log("Source totals:", sourceTotals);
    console.log("Total income:", total);
    
    // Inventory source IDs to exclude
    const inventorySourceIds = [5, 6, 7];
    let inventoryTotal = 0;
    const regularSources = [];
    
    // Calculate inventory total and filter sources
    incomeSources.forEach(source => {
        if (inventorySourceIds.includes(source.id)) {
            inventoryTotal += sourceTotals[source.id] || 0;
            console.log(`Inventory source ${source.name}: ${sourceTotals[source.id] || 0}`);
        } else {
            regularSources.push(source);
        }
    });
    
    // Also check for inventory sales from records with source_id 999
    const inventoryFromRecords = sourceTotals[999] || 0;
    if (inventoryFromRecords > 0) {
        inventoryTotal += inventoryFromRecords;
    }
    
    console.log("Total inventory amount:", inventoryTotal);
    
    let html = '';
    
    // ALWAYS show inventory card (even with zero)
    const inventoryPercentage = total > 0 ? ((inventoryTotal / total) * 100).toFixed(1) : 0;
    html += `
        <div class="source-card" onclick="window.location.href='/inventory'" style="cursor: pointer;">
            <div class="source-card-header" style="background: linear-gradient(135deg, #17a2b8, #138496)">
                <div class="source-name">
                    <span>📦</span>
                    <span>Inventory (Mauzo ya Bidhaa)</span>
                </div>
                <div class="source-percentage">${inventoryPercentage}%</div>
            </div>
            <div class="source-card-body">
                <div class="amount-row">
                    <span class="amount-label">Jumla ya Mapato</span>
                    <span class="amount-value">TSh ${inventoryTotal.toLocaleString()}</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width: ${inventoryPercentage}%; background: linear-gradient(90deg, #17a2b8, #138496)"></div>
                </div>
                <div class="target-info">
                    <span>🎯 Lengo: TSh 0</span>
                    <span>${inventoryPercentage}%</span>
                </div>
                <button class="edit-btn" onclick="event.stopPropagation(); window.location.href='/inventory'">📦 Endelea Kwenye Inventory</button>
            </div>
        </div>
    `;
    
    // Add regular sources
    regularSources.forEach(source => {
        const totalAmount = sourceTotals[source.id] || 0;
        const percentage = total > 0 ? ((totalAmount / total) * 100).toFixed(1) : 0;
        const target = source.target || 0;
        const progress = target > 0 ? (totalAmount / target) * 100 : 0;
        
        html += `
            <div class="source-card" onclick="showSourceDetails(${source.id})">
                <div class="source-card-header" style="background: linear-gradient(135deg, ${source.color}, #1a2a6e)">
                    <div class="source-name"><span>${source.icon || '💰'}</span> ${escapeHtml(source.name)}</div>
                    <div class="source-percentage">${percentage}%</div>
                </div>
                <div class="source-card-body">
                    <div class="amount-row"><span class="amount-label">Jumla ya Mapato</span><span class="amount-value">TSh ${totalAmount.toLocaleString()}</span></div>
                    <div class="progress-bar"><div class="progress-fill" style="width: ${Math.min(progress, 100)}%"></div></div>
                    <div class="target-info"><span>🎯 Lengo: TSh ${target.toLocaleString()}</span><span>${progress.toFixed(0)}%</span></div>
                    <button class="edit-btn" onclick="event.stopPropagation(); openAddIncomeModal(${source.id})">➕ Ongeza Mapato</button>
                </div>
            </div>
        `;
    });
    
    grid.innerHTML = html;
    console.log("Grid rendered with inventory card");
}

function updateSummaryStats() {
    const total = incomeRecords.reduce((sum, r) => sum + r.amount, 0);
    const totalTarget = globalTarget;
    const progress = totalTarget > 0 ? (total / totalTarget) * 100 : 0;
    
    document.getElementById('totalAmount').innerHTML = `TSh ${total.toLocaleString()}`;
    document.getElementById('summaryTotal').innerHTML = `TSh ${total.toLocaleString()}`;
    document.getElementById('summaryTarget').innerHTML = `TSh ${totalTarget.toLocaleString()}`;
    document.getElementById('targetProgressMsg').innerHTML = `${progress.toFixed(1)}% imefikiwa`;
    
    const now = new Date();
    const currentMonth = now.getMonth();
    const currentYear = now.getFullYear();
    const monthlyTotal = incomeRecords.filter(r => {
        const d = new Date(r.date);
        return d.getMonth() === currentMonth && d.getFullYear() === currentYear;
    }).reduce((sum, r) => sum + r.amount, 0);
    document.getElementById('summaryMonthly').innerHTML = `TSh ${monthlyTotal.toLocaleString()}`;
    
    const oneWeekAgo = new Date(now);
    oneWeekAgo.setDate(now.getDate() - 7);
    const weeklyTotal = incomeRecords.filter(r => new Date(r.date) >= oneWeekAgo).reduce((sum, r) => sum + r.amount, 0);
    document.getElementById('summaryWeekly').innerHTML = `TSh ${weeklyTotal.toLocaleString()}`;
}

function updateCharts() {
    const total = incomeRecords.reduce((sum, r) => sum + r.amount, 0);
    const sourceTotals = {};
    incomeSources.forEach(s => { sourceTotals[s.id] = { name: s.name, color: s.color, total: 0 }; });
    incomeRecords.forEach(r => { if (sourceTotals[r.source_id]) sourceTotals[r.source_id].total += r.amount; });
    
    const pieData = Object.values(sourceTotals).filter(s => s.total > 0);
    const pieCtx = document.getElementById('pieChart').getContext('2d');
    if (pieChart) pieChart.destroy();
    pieChart = new Chart(pieCtx, {
        type: 'pie',
        data: { labels: pieData.map(s => s.name), datasets: [{ data: pieData.map(s => s.total), backgroundColor: pieData.map(s => s.color) }] },
        options: { responsive: true, maintainAspectRatio: true }
    });
    
    const monthlyData = {};
    for (let i = 5; i >= 0; i--) {
        const d = new Date(); d.setMonth(d.getMonth() - i);
        const key = `${d.getFullYear()}-${d.getMonth() + 1}`;
        monthlyData[key] = { month: d.toLocaleString('default', { month: 'short' }), total: 0 };
    }
    incomeRecords.forEach(r => {
        const d = new Date(r.date);
        const key = `${d.getFullYear()}-${d.getMonth() + 1}`;
        if (monthlyData[key]) monthlyData[key].total += r.amount;
    });
    
    const barCtx = document.getElementById('barChart').getContext('2d');
    if (barChart) barChart.destroy();
    barChart = new Chart(barCtx, {
        type: 'bar',
        data: { labels: Object.values(monthlyData).map(m => m.month), datasets: [{ label: 'Mapato (TSh)', data: Object.values(monthlyData).map(m => m.total), backgroundColor: '#1a2a6e', borderRadius: 10 }] },
        options: { responsive: true, maintainAspectRatio: true, scales: { y: { beginAtZero: true, ticks: { callback: v => `TSh ${v.toLocaleString()}` } } } }
    });
}

// Target Settings Functions
function openTargetSettingsModal() {
    document.getElementById('targetSettingsModal').classList.add('active');
    loadTargetSettings();
}

function closeTargetSettingsModal() {
    document.getElementById('targetSettingsModal').classList.remove('active');
}

function loadTargetSettings() {
    // Set global target
    document.getElementById('globalTargetInput').value = globalTarget;
    document.getElementById('currentGlobalTarget').innerHTML = `TSh ${globalTarget.toLocaleString()}`;
    
    // Build source targets list
    let html = '';
    incomeSources.forEach(source => {
        const currentTarget = source.target || 0;
        html += `
            <div class="target-item">
                <div>
                    <span class="name">${source.icon || '💰'} ${escapeHtml(source.name)}</span>
                    <div class="current">Lengo la sasa: TSh ${currentTarget.toLocaleString()}</div>
                </div>
                <input type="number" id="source_target_${source.id}" value="${currentTarget}" step="100000" placeholder="Weka Lengo">
            </div>
        `;
    });
    document.getElementById('sourceTargetsList').innerHTML = html;
    
    // Update summary
    updateTargetSummary();
}

function updateTargetSummary() {
    const total = incomeRecords.reduce((sum, r) => sum + r.amount, 0);
    const totalTargets = globalTarget;
    const overallProgress = totalTargets > 0 ? (total / totalTargets) * 100 : 0;
    
    document.getElementById('totalTargetsSum').innerHTML = `TSh ${totalTargets.toLocaleString()}`;
    document.getElementById('currentIncomeSum').innerHTML = `TSh ${total.toLocaleString()}`;
    document.getElementById('overallProgress').innerHTML = `${overallProgress.toFixed(1)}%`;
}

async function saveAllTargets() {
    // Save global target
    const newGlobalTarget = parseInt(document.getElementById('globalTargetInput').value) || 0;
    globalTarget = newGlobalTarget;
    
    // Save per-source targets
    incomeSources.forEach(source => {
        const targetInput = document.getElementById(`source_target_${source.id}`);
        if (targetInput) {
            source.target = parseInt(targetInput.value) || 0;
        }
    });
    
    // Update display
    updateSummaryStats();
    renderSourcesGrid();
    updateTargetSummary();
    
    closeTargetSettingsModal();
    alert('✅ Malengo yamehifadhiwa kikamilifu!');
}

function openAddSourceModal() { document.getElementById('addSourceModal').classList.add('active'); }
function closeAddSourceModal() { document.getElementById('addSourceModal').classList.remove('active'); }

async function showSourceDetails(sourceId) {
    const source = incomeSources.find(s => s.id === sourceId);
    if (!source) return;
    const sourceRecords = incomeRecords.filter(r => r.source_id === sourceId);
    const totalAmount = sourceRecords.reduce((sum, r) => sum + r.amount, 0);
    const target = source.target || 0;
    const progress = target > 0 ? (totalAmount / target) * 100 : 0;
    
    let transactionsHtml = '';
    sourceRecords.sort((a, b) => new Date(b.date) - new Date(a.date)).forEach(record => {
        transactionsHtml += `<div class="transaction-item"><div><div class="transaction-date">📅 ${record.date}</div><div style="font-size:12px;">${escapeHtml(record.note || 'Mapato')}</div></div><div class="transaction-amount">TSh ${record.amount.toLocaleString()}</div></div>`;
    });
    
    document.getElementById('detailTitle').innerHTML = `📊 ${escapeHtml(source.name)}`;
    document.getElementById('detailBody').innerHTML = `
        <div class="detail-stats"><div class="detail-stat"><div class="label">Jumla ya Mapato</div><div class="value">TSh ${totalAmount.toLocaleString()}</div></div>
        <div class="detail-stat"><div class="label">Lengo la Mwaka</div><div class="value">TSh ${target.toLocaleString()}</div></div>
        <div class="detail-stat"><div class="label">Ufanisi</div><div class="value">${progress.toFixed(1)}%</div></div></div>
        <div class="progress-bar"><div class="progress-fill" style="width: ${Math.min(progress, 100)}%"></div></div>
        <h4 style="margin:15px 0;">📋 Historia ya Mapato</h4>
        <div class="transaction-list">${transactionsHtml || '<div style="text-align:center;padding:20px;">📭 Hakuna rekodi</div>'}</div>
        <button class="edit-btn" onclick="closeSourceDetailModal(); openAddIncomeModal(${sourceId})" style="margin-top:15px;">➕ Ongeza Mapato</button>
    `;
    document.getElementById('sourceDetailModal').classList.add('active');
}

function closeSourceDetailModal() { document.getElementById('sourceDetailModal').classList.remove('active'); }

function openAddIncomeModal(sourceId = null) {
    const sourceSelect = document.getElementById('incomeSource');
    sourceSelect.innerHTML = incomeSources.map(s => `<option value="${s.id}" ${s.id === sourceId ? 'selected' : ''}>${escapeHtml(s.name)}</option>`).join('');
    document.getElementById('incomeDate').value = new Date().toISOString().split('T')[0];
    document.getElementById('addIncomeModal').classList.add('active');
}
function closeAddIncomeModal() { document.getElementById('addIncomeModal').classList.remove('active'); }

document.getElementById('addSourceForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const newSource = {
        id: incomeSources.length + 1,
        name: document.getElementById('sourceName').value,
        color: document.getElementById('sourceColor').value,
        target: parseInt(document.getElementById('sourceTarget').value) || 0,
        description: document.getElementById('sourceDescription').value,
        icon: '💰'
    };
    incomeSources.push(newSource);
    renderAll();
    closeAddSourceModal();
    alert('✅ Chanzo kimeongezwa!');
});

document.getElementById('addIncomeForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const sourceId = parseInt(document.getElementById('incomeSource').value);
    const source = incomeSources.find(s => s.id === sourceId);
    const newIncome = {
        id: incomeRecords.length + 1,
        source_id: sourceId,
        source_name: source ? source.name : 'Unknown',
        amount: parseInt(document.getElementById('incomeAmount').value),
        date: document.getElementById('incomeDate').value,
        note: document.getElementById('incomeNote').value || 'Mapato'
    };
    if (!newIncome.amount || newIncome.amount <= 0) { alert('Tafadhali weka kiasi sahihi'); return; }
    incomeRecords.push(newIncome);
    renderAll();
    closeAddIncomeModal();
    alert('✅ Mapato yameongezwa!');
});


function formatNumber(num) {
    if (!num && num !== 0) return '0';
    return Math.round(num).toLocaleString();
}
function escapeHtml(text) { if (!text) return ''; return text.replace(/[&<>]/g, m => m === '&' ? '&amp;' : (m === '<' ? '&lt;' : '&gt;')); }

loadIncomeData();
</script>
