{% extends "base.html" %}

{% block title %}Mapato - Kwaya Mt. Bonifasi{% endblock %}

{% block content %}
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    .income-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }
    
    .income-header {
        background: linear-gradient(135deg, #1a2a6e, #2a3a7e);
        padding: 25px 30px;
        border-radius: 20px;
        color: white;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }
    
    .income-header h1 {
        color: #FFD700;
        margin: 0;
        font-size: 28px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .header-buttons {
        display: flex;
        gap: 12px;
    }
    
    .settings-icon-btn {
        background: rgba(255,255,255,0.2);
        border: none;
        border-radius: 50%;
        width: 45px;
        height: 45px;
        cursor: pointer;
        font-size: 22px;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .settings-icon-btn:hover {
        background: #FFD700;
        color: #1a2a6e;
        transform: rotate(90deg);
    }
    
    .total-amount-card {
        background: rgba(255,255,255,0.15);
        padding: 15px 25px;
        border-radius: 20px;
        text-align: center;
    }
    
    .total-amount-card .label {
        font-size: 12px;
        opacity: 0.8;
    }
    
    .total-amount-card .amount {
        font-size: 32px;
        font-weight: bold;
        color: #FFD700;
    }
    
    .summary-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .summary-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        text-align: center;
        border-left: 5px solid;
        transition: transform 0.2s;
    }
    
    .summary-card:hover { transform: translateY(-3px); }
    .summary-card.total { border-left-color: #1a2a6e; }
    .summary-card.monthly { border-left-color: #28a745; }
    .summary-card.weekly { border-left-color: #fd7e14; }
    .summary-card.target { border-left-color: #dc3545; }
    
    .summary-card .icon { font-size: 40px; margin-bottom: 10px; }
    .summary-card .title { font-size: 13px; color: #666; }
    .summary-card .value { font-size: 28px; font-weight: bold; color: #1a2a6e; margin-top: 5px; }
    .summary-card .sub { font-size: 11px; color: #888; margin-top: 5px; }
    
    .add-source-btn {
        background: linear-gradient(135deg, #28a745, #1e7e34);
        color: white;
        border: none;
        padding: 12px 25px;
        border-radius: 40px;
        cursor: pointer;
        font-weight: bold;
        font-size: 14px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 25px;
        transition: all 0.3s;
    }
    
    .add-source-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(40,167,69,0.4);
    }
    
    .sources-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 25px;
        margin-bottom: 30px;
    }
    
    .source-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        transition: all 0.3s;
        cursor: pointer;
    }
    
    .source-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }
    
    .source-card-header {
        background: linear-gradient(135deg, #1a2a6e, #2a3a7e);
        padding: 20px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .source-name {
        font-size: 18px;
        font-weight: bold;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .source-percentage {
        background: rgba(255,255,255,0.2);
        padding: 5px 12px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: bold;
    }
    
    .source-card-body {
        padding: 20px;
    }
    
    .amount-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
    }
    
    .amount-label {
        color: #666;
        font-size: 13px;
    }
    
    .amount-value {
        font-size: 24px;
        font-weight: bold;
        color: #28a745;
    }
    
    .progress-bar {
        background: #e0e0e0;
        border-radius: 10px;
        height: 10px;
        overflow: hidden;
        margin: 15px 0;
    }
    
    .progress-fill {
        background: linear-gradient(90deg, #28a745, #1e7e34);
        height: 100%;
        border-radius: 10px;
        transition: width 0.5s;
    }
    
    .target-info {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        color: #666;
        margin-top: 5px;
    }
    
    .edit-btn {
        background: #17a2b8;
        color: white;
        border: none;
        padding: 8px 15px;
        border-radius: 20px;
        cursor: pointer;
        font-size: 12px;
        margin-top: 10px;
        width: 100%;
    }
    
    .charts-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
        margin-top: 30px;
    }
    
    .chart-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    
    .chart-card h3 {
        color: #1a2a6e;
        margin-bottom: 20px;
        border-left: 4px solid #FFD700;
        padding-left: 12px;
    }
    
    .chart-container {
        position: relative;
        height: 300px;
    }
    
    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.8);
        z-index: 2000;
        justify-content: center;
        align-items: center;
    }
    
    .modal.active {
        display: flex;
    }
    
    .modal-content {
        background: white;
        border-radius: 25px;
        width: 90%;
        max-width: 600px;
        max-height: 85vh;
        overflow-y: auto;
        animation: modalFadeIn 0.3s;
    }
    
    @keyframes modalFadeIn {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .modal-header {
        background: linear-gradient(135deg, #1a2a6e, #2a3a7e);
        color: #FFD700;
        padding: 18px 25px;
        border-radius: 25px 25px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .modal-header h2 {
        margin: 0;
        font-size: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .close-modal {
        background: none;
        border: none;
        color: #FFD700;
        font-size: 28px;
        cursor: pointer;
    }
    
    .modal-body {
        padding: 25px;
    }
    
    .form-group {
        margin-bottom: 20px;
    }
    
    .form-group label {
        display: block;
        font-weight: bold;
        margin-bottom: 8px;
        color: #1a2a6e;
    }
    
    .form-group input, .form-group select {
        width: 100%;
        padding: 12px;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        font-size: 14px;
    }
    
    .form-group input:focus {
        outline: none;
        border-color: #FFD700;
    }
    
    .submit-btn {
        background: linear-gradient(135deg, #28a745, #1e7e34);
        color: white;
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 40px;
        font-weight: bold;
        font-size: 16px;
        cursor: pointer;
        margin-top: 10px;
    }
    
    .detail-modal-content {
        max-width: 600px;
    }
    
    .detail-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        margin-bottom: 20px;
    }
    
    .detail-stat {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 15px;
        text-align: center;
    }
    
    .detail-stat .label {
        font-size: 12px;
        color: #666;
    }
    
    .detail-stat .value {
        font-size: 24px;
        font-weight: bold;
        color: #1a2a6e;
    }
    
    .transaction-list {
        max-height: 300px;
        overflow-y: auto;
    }
    
    .transaction-item {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .transaction-date {
        font-size: 12px;
        color: #666;
    }
    
    .transaction-amount {
        font-weight: bold;
        color: #28a745;
    }
    
    /* Target Settings Modal */
    .target-settings-section {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
    }
    
    .target-settings-section h3 {
        color: #1a2a6e;
        margin-bottom: 15px;
        font-size: 16px;
        border-left: 3px solid #FFD700;
        padding-left: 10px;
    }
    
    .target-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid #e0e0e0;
    }
    
    .target-item:last-child {
        border-bottom: none;
    }
    
    .target-item .name {
        font-weight: bold;
        color: #333;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .target-item .current {
        font-size: 12px;
        color: #666;
    }
    
    .target-item input {
        width: 200px;
        padding: 8px 12px;
        border: 1px solid #ddd;
        border-radius: 12px;
        text-align: right;
    }
    
    .target-summary {
        background: linear-gradient(135deg, #1a2a6e, #2a3a7e);
        border-radius: 16px;
        padding: 15px;
        margin-top: 20px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }
    
    .target-summary .label {
        font-size: 12px;
        opacity: 0.8;
    }
    
    .target-summary .value {
        font-size: 24px;
        font-weight: bold;
        color: #FFD700;
    }
    
    @media (max-width: 800px) {
        .summary-row { grid-template-columns: repeat(2, 1fr); }
        .charts-section { grid-template-columns: 1fr; }
        .sources-grid { grid-template-columns: 1fr; }
        .target-item { flex-direction: column; align-items: flex-start; gap: 10px; }
        .target-item input { width: 100%; }
    }
</style>

